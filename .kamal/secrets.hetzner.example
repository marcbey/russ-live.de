# Diese Datei wird von Kamal beim Deploy ausgewertet.
# Lokal dürfen die Werte aus `.env` bzw. `config/master.key` kommen.
# In GitHub Actions sollten dieselben Namen als Environment-Secrets gesetzt sein.
#
# RUSS_LIVE_PRIMARY_DB_PASSWORD gehört zum read-only Benutzer `russ_live_de_reader`
# auf Stuttgarts Primärdatenbank. RUSS_LIVE_OPERATIONAL_DB_PASSWORD gehört zum
# writable Benutzer `russ_live_de` für Russ-Live-Queue, Cache und Cable.

KAMAL_REGISTRY_PUSH_TOKEN=$(test -f .env && grep -m 1 '^KAMAL_REGISTRY_PUSH_TOKEN=' .env | cut -d= -f2-)
KAMAL_REGISTRY_PULL_PASSWORD=$(test -f .env && grep -m 1 '^KAMAL_REGISTRY_PULL_PASSWORD=' .env | cut -d= -f2-)
RAILS_MASTER_KEY=$(test -f config/master.key && tr -d '\r\n' < config/master.key)
RUSS_LIVE_PRIMARY_DB_PASSWORD=$(test -f .env && grep -m 1 '^RUSS_LIVE_PRIMARY_DB_PASSWORD=' .env | cut -d= -f2-)
RUSS_LIVE_OPERATIONAL_DB_PASSWORD=$(test -f .env && grep -m 1 '^RUSS_LIVE_OPERATIONAL_DB_PASSWORD=' .env | cut -d= -f2-)
MEDIA_PROXY_SECRET=$(test -f .env && grep -m 1 '^MEDIA_PROXY_SECRET=' .env | cut -d= -f2-)
