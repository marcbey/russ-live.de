<% contact_image = contact.build_contact_image_with_defaults %>
<% form_url = contact.persisted? ? backend_contact_path(contact) : backend_contacts_path %>
<% form_method = contact.persisted? ? :patch : :post %>
<% form_id = dom_id(contact, :editor_form) %>

<div class="editor-panel" data-controller="reference-image-crop-preview">
  <div class="editor-tabs">
    <div class="editor-tab-list" role="tablist" aria-label="Ansprechpartner bearbeiten">
      <% { "contact" => "Ansprechpartner", "image" => "Bild" }.each do |tab, label| %>
        <%= button_tag label,
                       type: "button",
                       class: "editor-tab #{'is-active' if active_editor_tab == tab}",
                       role: "tab",
                       aria: { selected: (active_editor_tab == tab).to_s },
                       data: {
                         action: "reference-image-crop-preview#selectTab",
                         reference_image_crop_preview_target: "tab",
                         reference_image_crop_preview_tab_param: tab
                       } %>
      <% end %>
    </div>

    <div class="editor-actions editor-tabs-actions">
      <button type="submit" form="<%= form_id %>" class="button button-compact">Speichern</button>
      <% if contact.persisted? %>
        <%= button_to "Ansprechpartner löschen",
                      backend_contact_path(contact, query: @query_filter),
                      method: :delete,
                      class: "button button-danger button-compact",
                      form: { data: { turbo_confirm: "Diesen Ansprechpartner wirklich löschen?" } } %>
        <%= link_to "Neuer Ansprechpartner",
                    new_backend_contact_path(query: @query_filter),
                    class: "button button-success button-compact" %>
      <% end %>
    </div>
  </div>

  <%= form_with model: contact,
                url: form_url,
                method: form_method,
                class: "editor-form",
                html: { id: form_id, multipart: true },
                data: { turbo: false } do |form| %>
    <%= hidden_field_tag :query, @query_filter if @query_filter.present? %>
    <%= hidden_field_tag :editor_tab, active_editor_tab, data: { reference_image_crop_preview_target: "editorTab" } %>

    <% if contact.errors.any? || contact_image.errors.any? %>
      <div class="form-errors">
        <p>Bitte prüfe die markierten Angaben.</p>
        <ul>
          <% (contact.errors.full_messages + contact_image.errors.full_messages).uniq.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="editor-tab-panel"
         data-reference-image-crop-preview-target="panel"
         data-reference-image-crop-preview-tab-param="contact"
         <%= "hidden" unless active_editor_tab == "contact" %>>
      <%= render "contact_fields", form: form %>
    </div>

    <div class="editor-tab-panel"
         data-reference-image-crop-preview-target="panel"
         data-reference-image-crop-preview-tab-param="image"
         <%= "hidden" unless active_editor_tab == "image" %>>
      <%= render "backend/shared/simple_image_fields", image: contact_image, image_source: contact_image_source(contact_image), param_key: "contact_image", show_meta_fields: false %>
    </div>
  <% end %>
</div>
