<% content_for :title, "Jobs" %>

<main class="backend-shell backend-inbox-shell">
  <%= render "backend/shared/navigation" %>

  <header class="backend-topbar backend-topbar-sticky backend-inbox-topbar">
    <div class="backend-topbar-title">
      <p class="eyebrow">Russ Live</p>
      <h1>Jobs</h1>
    </div>
    <div class="backend-topbar-actions">
      <%= link_to "Neuer Job",
                  new_backend_job_path(status: (@status_filter unless @status_filter == "all"), query: @query_filter),
                  class: "button button-secondary button-compact" %>
      <%= link_to "Zur Jobseite", jobs_path, class: "button button-compact" %>
    </div>
  </header>

  <div class="backend-split backend-inbox-split">
    <aside class="backend-list-column">
      <div class="backend-list-toolbar">
        <nav class="backend-status-row" aria-label="Jobs nach Status filtern">
          <% Backend::JobsController::FILTERS.each do |filter| %>
            <% label = { "all" => "Alle", "draft" => "Entwürfe", "published" => "Veröffentlicht" }.fetch(filter) %>
            <%= link_to label,
                        backend_jobs_path(status: (filter unless filter == "all"), query: @query_filter),
                        class: "status-chip #{'status-chip-active' if @status_filter == filter}",
                        aria: { current: ("page" if @status_filter == filter) } %>
          <% end %>
        </nav>

        <%= form_with url: backend_jobs_path, method: :get, class: "filter-form", data: { turbo: false, controller: "filter-clear" } do |form| %>
          <%= form.hidden_field :status, value: (@status_filter unless @status_filter == "all") %>
          <div class="filter-grid">
            <div class="filter-search-field filter-search-field-full">
              <%= form.label :query, "Suche", class: "form-label" %>
              <div class="filter-control">
                <%= form.text_field :query,
                                    value: @query_filter,
                                    placeholder: "Titel, Ort, Bereich, Kontakt",
                                    class: "form-input filter-input-with-clear",
                                    data: { filter_clear_target: "input", action: "input->filter-clear#toggle" } %>
                <%= button_tag "×",
                               type: "button",
                               class: "filter-clear filter-input-clear #{'is-visible' if @query_filter.present?}",
                               aria: { label: "Suche löschen" },
                               data: { filter_clear_target: "clear", action: "filter-clear#clear" } %>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <div class="backend-reference-list-scroll">
        <div class="backend-reference-list">
          <% if @jobs.any? %>
            <% @jobs.each do |job| %>
              <%= link_to backend_jobs_path(status: (@status_filter unless @status_filter == "all"), query: @query_filter, job_id: job.id),
                          class: "backend-reference-list-item #{'is-active' if @selected_job&.id == job.id}" do %>
                <span class="backend-reference-list-title"><%= job.title %></span>
                <span class="backend-reference-list-meta"><%= [job.category_list, job.location].compact_blank.join(" · ") %></span>
                <span class="status-badge"><%= job.display_status %></span>
              <% end %>
            <% end %>
          <% else %>
            <p class="empty-state">Keine Jobs zur aktuellen Filterung.</p>
          <% end %>
        </div>
      </div>
    </aside>

    <section class="backend-editor-column backend-inbox-editor-column">
      <% if @selected_job.present? %>
        <%= render "editor_panel", job: @selected_job, contacts: @contacts, active_editor_tab: @active_editor_tab %>
      <% else %>
        <p class="empty-state">Wähle einen Job aus oder lege einen neuen Job an.</p>
      <% end %>
    </section>
  </div>
</main>
