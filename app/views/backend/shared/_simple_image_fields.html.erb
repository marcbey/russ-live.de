<% show_meta_fields = local_assigns.fetch(:show_meta_fields, true) %>

<section class="backend-section backend-section-media event-image-section">
  <div class="backend-section-body">
    <div class="event-image-crop-shell">
      <div class="event-image-crop-editor">
        <div class="event-image-crop-frame"
             data-reference-image-crop-preview-target="previewFrame">
          <% if image_source.present? %>
            <%= image_tag image_source,
                          alt: image.display_alt_text,
                          class: "event-image-crop-preview-image",
                          data: { reference_image_crop_preview_target: "previewImage" } %>
          <% else %>
            <img alt=""
                 class="event-image-crop-preview-image is-hidden"
                 data-reference-image-crop-preview-target="previewImage">
          <% end %>
          <p class="event-image-crop-placeholder<%= " is-hidden" if image_source.present? %>"
             data-role="event-image-crop-placeholder">
            Noch kein Bild ausgewählt.
          </p>
        </div>

        <aside class="event-image-crop-sidebar">
          <div class="event-image-meta-inline-form">
            <label class="form-label" for="<%= param_key %>_file">Bild</label>
            <%= file_field_tag "#{param_key}[file]",
                               accept: "image/*",
                               id: "#{param_key}_file",
                               class: "form-input",
                               data: { reference_image_crop_preview_target: "fileInput" } %>
            <% image_file_metadata = stored_image_file_metadata(image) %>
            <dl class="event-image-file-meta"
                aria-label="Aktuelle Bilddatei"
                data-reference-image-crop-preview-target="fileMeta"
                <%= "hidden" if image_file_metadata.empty? %>>
              <% image_file_metadata.each do |label, value| %>
                <div>
                  <dt><%= label %></dt>
                  <dd><%= value %></dd>
                </div>
              <% end %>
            </dl>
          </div>

          <div class="event-image-sidebar-divider" aria-hidden="true"></div>

          <% if show_meta_fields %>
            <div class="event-image-meta-inline-form">
              <label class="form-label" for="<%= param_key %>_alt_text">Alt-Text</label>
              <%= text_field_tag "#{param_key}[alt_text]", image.alt_text, id: "#{param_key}_alt_text", class: "form-input" %>
            </div>

            <div class="event-image-meta-inline-form">
              <label class="form-label" for="<%= param_key %>_sub_text">Copyright</label>
              <%= text_field_tag "#{param_key}[sub_text]", image.sub_text, id: "#{param_key}_sub_text", class: "form-input", placeholder: "Copyright unter dem Bild (optional)" %>
            </div>
          <% end %>

          <% if image.image? %>
            <label class="form-checkbox">
              <%= check_box_tag "#{param_key}[remove_image]", "1", false %>
              <span>Bild entfernen</span>
            </label>
          <% end %>
        </aside>
      </div>
    </div>
  </div>
</section>
