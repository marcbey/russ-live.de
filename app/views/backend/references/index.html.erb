<% content_for :title, "Referenzen" %>

<main class="backend-shell backend-inbox-shell">
  <%= render "backend/shared/navigation" %>

  <header class="backend-topbar backend-topbar-sticky backend-inbox-topbar">
    <div class="backend-topbar-title">
      <p class="eyebrow">Russ Live</p>
      <h1>Referenzen</h1>
    </div>
  </header>

  <div class="backend-split backend-inbox-split">
    <aside class="backend-list-column">
      <div class="backend-list-toolbar">
        <div class="backend-list-toolbar-actions">
          <%= link_to "Neue Referenz",
                      new_backend_reference_path(status: (@status_filter unless @status_filter == "all"), query: @query_filter),
                      class: "button button-success button-compact" %>
        </div>

        <nav class="backend-status-row" aria-label="Referenzen filtern">
          <% Backend::ReferencesController::FILTERS.each do |filter| %>
            <% label = { "all" => "Alle", "slider" => "Slider", "draft" => "Entwürfe", "published" => "Veröffentlicht" }.fetch(filter) %>
            <%= link_to label,
                        backend_references_path(status: (filter unless filter == "all"), query: @query_filter),
                        class: "status-chip #{'status-chip-active' if @status_filter == filter}",
                        aria: { current: ("page" if @status_filter == filter) } %>
          <% end %>
        </nav>

        <%= form_with url: backend_references_path, method: :get, class: "filter-form", data: { turbo: false, controller: "filter-clear" } do |form| %>
          <%= form.hidden_field :status, value: (@status_filter unless @status_filter == "all") %>
          <div class="filter-grid">
            <div class="filter-search-field filter-search-field-full">
              <%= form.label :query, "Suche", class: "form-label" %>
              <div class="filter-control">
                <%= form.text_field :query,
                                    value: @query_filter,
                                    placeholder: "Titel, Ort, Produktion",
                                    class: "form-input filter-input-with-clear",
                                    data: { filter_clear_target: "input", action: "input->filter-clear#toggle" } %>
                <%= button_tag "×",
                               type: "button",
                               class: "filter-clear filter-input-clear #{'is-visible' if @query_filter.present?}",
                               aria: { label: "Suche löschen" },
                               data: { filter_clear_target: "clear", action: "filter-clear#clear" } %>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <div class="backend-reference-list-scroll"
           data-controller="backend-list-focus"
           data-backend-list-focus-storage-key-value="<%= [@status_filter, @query_filter.presence || 'all'].join(':') %>">
        <div class="backend-reference-list">
          <% if @references.any? %>
            <% @references.each do |reference| %>
              <%= link_to backend_references_path(status: (@status_filter unless @status_filter == "all"), query: @query_filter, reference_id: reference.id),
                          class: "backend-reference-list-item #{'is-active' if @selected_reference&.id == reference.id}",
                          data: { action: "click->backend-list-focus#rememberScroll" } do %>
                <span class="backend-reference-list-title"><%= reference.title %></span>
                <span class="backend-reference-list-meta"><%= reference_date_label(reference) %> · <%= reference.location %></span>
                <span class="status-badge"><%= reference.display_status %></span>
              <% end %>
            <% end %>
          <% else %>
            <p class="empty-state">Keine Referenzen zur aktuellen Filterung.</p>
          <% end %>
        </div>
      </div>
    </aside>

    <section class="backend-editor-column backend-inbox-editor-column">
      <% if @selected_reference.present? %>
        <%= render "editor_panel", reference: @selected_reference, active_editor_tab: @active_editor_tab %>
      <% else %>
        <div class="empty-state">
          <p>Wähle eine Referenz aus oder lege eine neue Referenz an.</p>
          <%= link_to "Neue Referenz",
                      new_backend_reference_path(status: (@status_filter unless @status_filter == "all"), query: @query_filter),
                      class: "button button-success button-compact" %>
        </div>
      <% end %>
    </section>
  </div>
</main>
