<section class="backend-section">
  <div class="backend-section-body editor-grid">
    <div>
      <%= form.label :title, "Titel", class: "form-label" %>
      <%= form.text_field :title, class: "form-input" %>
    </div>
    <div>
      <%= form.label :display_date, "Datum", class: "form-label" %>
      <%= form.text_field :display_date,
                          value: reference.display_date_text,
                          class: "form-input",
                          placeholder: "z. B. 18.05.2026 oder Juni 2025 - März 2026" %>
      <p class="form-hint">Freie Anzeige für Website und Backend. Ein exaktes Datum wie `18.05.2026` wird intern automatisch übernommen.</p>
    </div>
    <div>
      <%= form.label :position, "Sortierung", class: "form-label" %>
      <%= form.number_field :position, class: "form-input", min: 1, step: 1 %>
      <p class="form-hint">`1` steht unten. Größere Zahlen wandern weiter nach oben.</p>
    </div>
    <div>
      <%= form.label :location, "Location", class: "form-label" %>
      <%= form.text_field :location, class: "form-input" %>
    </div>
    <div>
      <%= form.label :production, "Produktion", class: "form-label" %>
      <%= form.text_field :production, class: "form-input" %>
    </div>
    <div class="editor-grid-span-full">
      <%= form.label :tag_list, "Tags", class: "form-label" %>
      <%= form.text_field :tag_list, class: "form-input", placeholder: "Open Air, Clubkonzert, Ausstellung" %>
      <p class="form-hint">Komma- oder zeilengetrennt.</p>
    </div>
    <div>
      <%= form.label :status, "Status", class: "form-label" %>
      <%= form.select :status, [["Entwurf", "draft"], ["Veröffentlicht", "published"]], {}, class: "form-input" %>
    </div>
    <div class="editor-grid-span-full">
      <%= form.label :description, "Beschreibung (Deutsch)", class: "form-label" %>
      <%= form.text_area :description, rows: 5, class: "form-textarea" %>
    </div>
    <div class="editor-grid-span-full">
      <%= form.label :description_en, "Beschreibung (Englisch)", class: "form-label" %>
      <%= form.text_area :description_en, rows: 5, class: "form-textarea" %>
    </div>
  </div>
</section>
