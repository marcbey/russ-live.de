<% reference_image = reference.build_reference_image_with_defaults %>
<% form_url = reference.persisted? ? backend_reference_path(reference) : backend_references_path %>
<% form_method = reference.persisted? ? :patch : :post %>
<% form_id = dom_id(reference, :editor_form) %>

<div class="editor-panel" data-controller="reference-image-crop-preview">
  <div class="editor-tabs">
    <div class="editor-tab-list" role="tablist" aria-label="Referenz bearbeiten">
      <% { "reference" => "Referenz", "image" => "Bild" }.each do |tab, label| %>
        <%= button_tag label,
                       type: "button",
                       class: "editor-tab #{'is-active' if active_editor_tab == tab}",
                       role: "tab",
                       aria: { selected: (active_editor_tab == tab).to_s },
                       data: {
                         action: "reference-image-crop-preview#selectTab",
                         reference_image_crop_preview_target: "tab",
                         reference_image_crop_preview_tab_param: tab
                       } %>
      <% end %>
    </div>

    <div class="editor-actions editor-tabs-actions">
      <button type="submit" form="<%= form_id %>" class="button button-compact">Speichern</button>
      <% if reference.persisted? %>
        <%= button_to "Referenz löschen",
                      backend_reference_path(reference, status: (@status_filter unless @status_filter == "all"), query: @query_filter),
                      method: :delete,
                      class: "button button-danger button-compact",
                      form: { data: { turbo_confirm: "Diese Referenz wirklich löschen?" } } %>
        <%= link_to "Neue Referenz",
                    new_backend_reference_path(status: (@status_filter unless @status_filter == "all"), query: @query_filter),
                    class: "button button-success button-compact" %>
      <% end %>
    </div>
  </div>

  <%= form_with model: reference,
                url: form_url,
                method: form_method,
                class: "editor-form",
                html: { id: form_id, multipart: true },
                data: { turbo: false } do |form| %>
    <%= hidden_field_tag :status, (@status_filter unless @status_filter == "all") %>
    <%= hidden_field_tag :query, @query_filter if @query_filter.present? %>
    <%= hidden_field_tag :editor_tab, active_editor_tab, data: { reference_image_crop_preview_target: "editorTab" } %>

    <% if reference.errors.any? || reference_image.errors.any? %>
      <div class="form-errors">
        <p>Bitte prüfe die markierten Angaben.</p>
        <ul>
          <% (reference.errors.full_messages + reference_image.errors.full_messages).uniq.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="editor-tab-panel"
         data-reference-image-crop-preview-target="panel"
         data-reference-image-crop-preview-tab-param="reference"
         <%= "hidden" unless active_editor_tab == "reference" %>>
      <%= render "reference_fields", form: form, reference: reference %>
    </div>

    <div class="editor-tab-panel"
         data-reference-image-crop-preview-target="panel"
         data-reference-image-crop-preview-tab-param="image"
         <%= "hidden" unless active_editor_tab == "image" %>>
      <%= render "image_fields", form: form, reference: reference, reference_image: reference_image %>
    </div>
  <% end %>

</div>
