<header class="site-header page-header" aria-label="<%= t("public.header.main_aria") %>" data-controller="mobile-menu scrolled-header" data-mobile-menu-open-label-value="<%= t("public.header.menu_open") %>" data-mobile-menu-close-label-value="<%= t("public.header.menu_close") %>">
  <%= link_to root_path, class: "brand", aria: { label: t("public.header.home_aria") } do %>
    <%= image_tag "russ_live/logos/russ-live-logo-header.svg", alt: "Russ Live", class: "brand-mark" %>
  <% end %>

  <nav class="main-nav" aria-label="<%= t("public.header.nav_aria") %>" data-mobile-menu-target="nav">
    <% if backend_user? %>
      <%= link_to t("public.header.backend"), backend_root_path, class: "public-admin-nav-link", data: { role: "public-backend-nav-link" } %>
    <% end %>
    <div class="nav-item has-submenu">
      <%= link_to t("public.header.company"), unternehmen_path, class: public_nav_class(%i[unternehmen team referenzen]) %>
      <div class="nav-submenu" aria-label="<%= t("public.header.company_submenu_aria") %>">
        <%= link_to t("public.header.about"), unternehmen_path, public_nav_aria(:unternehmen) || {} %>
        <%= link_to t("public.header.team"), team_path, public_nav_aria(:team) || {} %>
        <%= link_to t("public.header.references"), referenzen_path, public_nav_aria(:referenzen) || {} %>
      </div>
    </div>
    <%= link_to t("public.header.services"), services_path, public_nav_aria(:services) || {} %>
    <% public_header_jobs = Array(@public_header_jobs) %>
    <% if public_header_jobs.any? %>
      <div class="nav-item has-submenu">
        <%= link_to t("public.header.jobs"), jobs_path, class: public_nav_class(%i[jobs job]) %>
        <div class="nav-submenu nav-submenu-jobs" aria-label="<%= t("public.header.jobs_submenu_aria") %>">
          <%= link_to t("public.header.all_jobs"), jobs_path(anchor: "jobs-list"), public_nav_aria(:jobs) || {} %>
          <% public_header_jobs.each do |job| %>
            <%= link_to job.title,
                        job_path(job.slug),
                        aria: { current: ("page" if @selected_job&.slug == job.slug) } %>
          <% end %>
        </div>
      </div>
    <% else %>
      <%= link_to t("public.header.jobs"), jobs_path, public_nav_aria(%i[jobs job]) || {} %>
    <% end %>
    <%= link_to t("public.header.press"), presse_path, public_nav_aria(%i[presse press_detail]) || {} %>
    <%= link_to t("public.header.contact"), kontakt_path, public_nav_aria(:kontakt) || {} %>
    <div class="language-switch" aria-label="<%= t("public.header.language_aria") %>">
      <% I18n.available_locales.each_with_index do |locale, index| %>
        <% if index.positive? %>
          <span class="language-switch-separator" aria-hidden="true">/</span>
        <% end %>
        <%= button_to locale.to_s.upcase,
                      locale_path(locale),
                      method: :post,
                      params: { return_to: locale_return_to_path },
                      form_class: "language-switch-form",
                      class: [ "language-switch-button", ("is-active" if I18n.locale == locale) ],
                      form: { aria: { label: t("public.header.language_switch", language: t("public.languages.#{locale}")) } },
                      lang: locale,
                      aria: { current: ("true" if I18n.locale == locale) } %>
      <% end %>
    </div>
  </nav>

  <button class="mobile-menu-button" type="button" aria-label="<%= t("public.header.menu_open") %>" data-mobile-menu-target="button" data-action="mobile-menu#toggle">
    <span></span>
    <span></span>
    <span></span>
  </button>
</header>
