<!DOCTYPE html>
<html lang="de">
  <head>
    <title><%= content_for(:title) || @page_meta&.fetch(:title, nil) || "Russ Live" %></title>
    <% if content_for?(:description) || @page_meta&.fetch(:description, nil).present? %>
      <meta name="description" content="<%= content_for(:description) || @page_meta[:description] %>">
    <% end %>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Russ Live">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= render "shared/public_fonts" if @page_key.present? %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="<%= content_for(:body_class) || @page_meta&.fetch(:body_class, nil) %>" data-controller="smooth-anchor">
    <%= link_to "Zum Inhalt springen", "#main-content", class: "skip-link" if @page_key.present? %>
    <%= render "shared/public_header" if @page_key.present? %>
    <%= render "layouts/flash_messages" %>
    <%= yield %>
    <%= render "shared/public_footer" if @page_key.present? %>
  </body>
</html>
