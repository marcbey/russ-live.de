<% if notice.present? || alert.present? %>
  <div class="flash-wrap">
    <% if notice.present? %>
      <p class="flash flash-notice" role="status"><%= notice %></p>
    <% end %>
    <% if alert.present? %>
      <p class="flash flash-alert" role="alert"><%= alert %></p>
    <% end %>
  </div>
<% end %>
