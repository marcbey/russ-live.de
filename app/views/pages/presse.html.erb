<main id="main-content" class="page-main public-page press-page" tabindex="-1" data-controller="press-search" data-press-search-locale-value="<%= I18n.locale == :de ? "de-DE" : "en-US" %>" data-press-search-singular-label-value="<%= t("press.index.count_singular") %>" data-press-search-plural-label-value="<%= t("press.index.count_plural") %>">
  <section id="press-overview" class="public-hero public-hero-dark section public-page-hero job-overview-hero press-hero" aria-labelledby="press-title">
    <div class="public-page-hero-media job-overview-hero-media press-hero-media">
      <%= image_tag "russ_live/press-overview-hero.jpg",
                    alt: t("press.index.hero.image_alt"),
                    width: 6000,
                    height: 4000,
                    decoding: "async",
                    fetchpriority: "high" %>
    </div>

    <div class="public-page-hero-copy job-overview-hero-copy press-hero-copy">
      <h1 id="press-title">
        <span><%= t("press.index.hero.title_first_line") %></span>
        <span><%= t("press.index.hero.title_second_line") %></span>
      </h1>
      <p><%= t("press.index.hero.intro") %></p>

      <form id="press-search" class="press-search" role="search" aria-label="<%= t("press.index.search.aria") %>" data-action="submit->press-search#submit">
        <label class="sr-only" for="press-search-input"><%= t("press.index.search.label") %></label>
        <div>
          <input id="press-search-input" type="search" name="q" autocomplete="off" placeholder="<%= t("press.index.search.placeholder") %>" data-press-search-target="input" data-action="input->press-search#render search->press-search#render">
          <button type="submit" aria-label="<%= t("press.index.search.submit_aria") %>">
            <span class="sr-only"><%= t("press.index.search.submit") %></span>
            <svg aria-hidden="true" viewBox="0 0 48 32" focusable="false">
              <path d="M1 16h42m0 0L29 2m14 14L29 30" />
            </svg>
          </button>
        </div>
      </form>
    </div>
  </section>

  <section class="public-section section press-directory" aria-labelledby="press-directory-title">
    <div class="press-directory-head">
      <div>
        <h2 id="press-directory-title"><%= t("press.index.directory.title") %></h2>
      </div>
      <p data-press-search-target="count"><%= @press_artist_count %> <%= @press_artist_count == 1 ? t("press.index.count_singular") : t("press.index.count_plural") %></p>
    </div>

    <div class="public-directory press-letter-grid" data-press-directory>
      <% @press_artist_groups.each do |letter, artists| %>
        <section class="press-letter-group" data-letter-group data-press-search-target="group">
          <h3><%= letter %></h3>
          <div class="press-artist-list">
            <% artists.each do |artist| %>
              <%= link_to press_artist_path(artist.slug), class: "public-card press-artist-card", data: { press_search_target: "card", artist_name: artist.name } do %>
                <span><%= artist.name %></span>
              <% end %>
            <% end %>
          </div>
        </section>
      <% end %>
    </div>
    <p class="press-empty" data-press-search-target="empty" hidden><%= t("press.index.empty") %></p>
  </section>

  <section class="public-section section press-contact-strip" aria-labelledby="press-contact-title">
    <div>
      <h2 id="press-contact-title"><%= t("press.index.contact.title") %></h2>
      <p><%= t("press.index.contact.text") %></p>
    </div>
    <article class="public-contact-card press-contact-card">
      <%= image_tag "russ_live/team/arnulf-woock.jpg", alt: "Arnulf Woock", loading: "lazy", decoding: "async", width: 600, height: 600 %>
      <div>
        <h3>Arnulf Woock</h3>
        <p><%= t("press.index.contact.role") %></p>
        <a href="mailto:arnulfwoock@michaelrussgmbh.de">arnulfwoock@michaelrussgmbh.de</a>
        <a href="tel:+497111635320">+49.711.16 353 20</a>
      </div>
    </article>
  </section>
</main>
