<main class="page-main job-page">
  <section class="section job-template-hero" aria-labelledby="job-title">
    <div class="job-template-hero-media">
      <%= image_tag job_image_source(@selected_job.job_image) || image_path("russ_live/jobs/cateringhilfen.jpg"),
                    alt: @selected_job.job_image&.display_alt_text || @selected_job.title %>
    </div>

    <div class="job-template-hero-copy">
      <h1 id="job-title"><%= @selected_job.title %></h1>
      <p><%= @selected_job.employment %></p>
      <div class="job-overview-hero-actions">
        <% if @selected_job.join_recruiting_url.present? %>
          <%= link_to "Jetzt bewerben", @selected_job.join_recruiting_url, class: "section-button", target: "_blank", rel: "noopener" %>
        <% end %>
        <%= link_to "Zur Übersicht", jobs_path, class: "section-button section-button-outline-light" %>
      </div>
    </div>
  </section>

  <section class="section job-detail" id="job-detail" aria-label="<%= @selected_job.detail_label %>">
    <article class="job-content">
      <div class="job-detail-hero" id="<%= @selected_job.detail_id %>">
        <p><%= @selected_job.intro %></p>
      </div>

      <div class="job-section">
        <p class="eyebrow">Tätigkeitsfeld</p>
        <ul class="job-list">
          <% @selected_job.responsibilities.each do |responsibility| %>
            <li><%= responsibility %></li>
          <% end %>
        </ul>
      </div>

      <div class="job-section">
        <p class="eyebrow">Anforderungen</p>
        <ul class="job-list">
          <% @selected_job.requirements.each do |requirement| %>
            <li><%= requirement %></li>
          <% end %>
        </ul>
      </div>

      <div class="job-apply">
        <h2>Wir freuen uns auf Deine Bewerbung!</h2>
        <% if @selected_job.join_recruiting_url.present? %>
          <%= link_to "Jetzt bewerben", @selected_job.join_recruiting_url, class: "section-button", target: "_blank", rel: "noopener" %>
        <% elsif @selected_job.contact&.email.present? %>
          <%= mail_to @selected_job.contact.email,
                      @selected_job.contact.email,
                      subject: @selected_job.application_email_subject,
                      class: "section-button" %>
        <% end %>
      </div>
    </article>

    <% if @selected_job.contact.present? %>
      <aside class="job-sidebar" aria-label="Ansprechpartner">
        <div class="job-contact">
          <p class="eyebrow">Ansprechpartner</p>
          <%= image_tag contact_image_source(@selected_job.contact.contact_image) || image_path("russ_live/team/sebastian-kraenzlein.jpg"),
                        alt: @selected_job.contact.contact_image&.display_alt_text || @selected_job.contact.name %>
          <h2><%= @selected_job.contact.name %></h2>
          <p><%= @selected_job.contact.role %></p>
          <p><a href="tel:<%= @selected_job.contact.tel_href %>"><%= @selected_job.contact.phone_number %></a></p>
          <p><%= mail_to @selected_job.contact.email, @selected_job.contact.email, subject: @selected_job.application_email_subject %></p>
        </div>
      </aside>
    <% end %>
  </section>
</main>
