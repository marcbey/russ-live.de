<main id="main-content" class="page-main public-page references-page" tabindex="-1" data-controller="reference-mosaic">
  <section class="public-hero public-hero-editorial public-page-hero references-hero" aria-labelledby="references-title">
    <div class="public-page-hero-media references-hero-media">
      <%= image_tag "russ_live/keyvisuals/services-stage-lights.jpg",
                    alt: "",
                    width: 2400,
                    height: 600,
                    decoding: "async",
                    fetchpriority: "high" %>
    </div>
    <div class="public-page-hero-copy references-hero-copy">
      <h1 id="references-title"><%= t("pages.references.hero.title") %></h1>
      <p><%= t("pages.references.hero.intro") %></p>
      <%= public_backend_link(
            label: t("public.actions.edit"),
            path: backend_references_path,
            aria_label: t("public.actions.edit_references"),
            wrapper_class: "public-admin-link-row"
          ) %>
    </div>
  </section>

  <% if @featured_references.any? %>
    <section id="referenz-highlights" class="public-section section references-featured-band" aria-label="<%= t("references.featured_aria") %>">
      <div class="references-featured-heading">
        <h2><%= t("references.featured_title") %></h2>
      </div>
      <%= render "pages/reference_slider", references: @featured_references, slider_classes: "klassik-slider reference-featured-slider", show_meta: false, flip_enabled: true %>
      <nav class="public-filter-nav references-filter-nav" aria-label="<%= t("references.filters.aria") %>">
        <button type="button" data-reference-tag="all" aria-pressed="true"><%= t("public.filters.all") %></button>
        <% @reference_tags.each do |reference_tag| %>
          <button type="button" data-reference-tag="<%= Reference.tag_slug(reference_tag) %>" aria-pressed="false"><%= reference_tag %></button>
        <% end %>
      </nav>
    </section>
  <% else %>
    <section class="public-section section references-filter-band" aria-label="<%= t("references.filters.aria") %>">
      <nav class="public-filter-nav references-filter-nav" aria-label="<%= t("references.filters.aria") %>">
        <button type="button" data-reference-tag="all" aria-pressed="true"><%= t("public.filters.all") %></button>
        <% @reference_tags.each do |reference_tag| %>
          <button type="button" data-reference-tag="<%= Reference.tag_slug(reference_tag) %>" aria-pressed="false"><%= reference_tag %></button>
        <% end %>
      </nav>
    </section>
  <% end %>

  <section class="public-section section references-band" aria-label="<%= t("references.grid_aria") %>">
    <% if @references.any? %>
      <div class="reference-grid reference-highlight-grid" data-layout="grid">
        <%= render partial: "pages/reference_card", collection: @references, as: :reference, locals: { force_square: true } %>
      </div>
    <% elsif @featured_references.blank? %>
      <p class="references-empty"><%= t("references.empty") %></p>
    <% end %>
  </section>
</main>
