<main class="page-main references-page" data-controller="reference-mosaic">
  <section class="references-hero" aria-labelledby="references-title">
    <div class="references-hero-media"><img src="<%= image_path "russ_live/keyvisuals/references-tropfen.png" %>" alt=""></div>
    <div class="references-hero-copy">
      <p class="eyebrow">Referenzen</p>
      <h1 id="references-title">Projekte, Projekte, Projekte...</h1>
      <p>Konzerte, Shows und Kulturformate aus Stuttgart und der Region.</p>
    </div>
    <nav class="references-year-nav" aria-label="Referenzen nach Jahr filtern">
      <button type="button" data-year="all" aria-pressed="true">Alle</button>
      <% @reference_years.each do |year| %>
        <button type="button" data-year="<%= year %>" aria-pressed="false"><%= year %></button>
      <% end %>
    </nav>
  </section>

  <section class="section references-band" aria-label="Referenzprojekte">
    <% if @references.any? %>
      <div class="reference-grid reference-highlight-grid" data-layout="grid">
        <%= render partial: "pages/reference_card", collection: @references, as: :reference %>
      </div>
    <% else %>
      <p class="references-empty">Aktuell sind keine Referenzen veröffentlicht.</p>
    <% end %>
  </section>
</main>
