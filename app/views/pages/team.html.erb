<% team_members = [
  { name: "Michaela Russ", key: :michaela_russ, image: "russ_live/team/michaela-russ.jpg" },
  { name: "Paul Woog", key: :paul_woog, image: "russ_live/team/paul-woog.jpg" },
  { name: "Johanna Backmund", key: :johanna_backmund, image: "russ_live/team/johanna-backmund.jpg" },
  { name: "Tim Wilka", key: :tim_wilka, image: "russ_live/team/tim-wilka.jpg" },
  { name: "Arnulf Woock", key: :arnulf_woock, image: "russ_live/team/arnulf-woock.jpg" },
  { name: "Sarah Sandner", key: :sarah_sandner, image: "russ_live/team/sarah-sandner.jpg" },
  { name: "Katharina Schopper", key: :katharina_schopper, image: "russ_live/team/katharina-schopper.jpg" },
  { name: "Chantal Erler", key: :chantal_erler, image: "russ_live/team/chantal-erler.jpg" },
  { name: "Tanja Ullenboom", key: :tanja_ullenboom, image: "russ_live/team/tanja-ullenboom.jpg" },
  { name: "Sebastian Kränzlein", key: :sebastian_kraenzlein, image: "russ_live/team/sebastian-kraenzlein.jpg" },
  { name: "Michael Wechselberger", key: :michael_wechselberger, image: "russ_live/team/michael-wechselberger.jpg" },
  { name: "Elke Vierneisel", key: :elke_vierneisel, image: "russ_live/team/elke-vierneisel.jpg" },
  { name: "Gabi Cremer", key: :gabi_cremer, image: "russ_live/team/gabi-cremer.jpg" },
  { name: "Jenny Hefner", key: :jenny_hefner, image: "russ_live/team/jenny-hefner.jpg" },
  { name: "Penny", key: :penny, image: "russ_live/team/penny.jpg" }
] %>

<main id="main-content" class="page-main public-page team-page" tabindex="-1">
  <section class="public-section section team-hero" aria-labelledby="team-title">
    <picture class="team-hero-media" aria-hidden="true">
      <source media="(max-width: 900px)" srcset="<%= image_path "russ_live/keyvisuals/Keyvisual_RussLive_hoch_mobil.jpg" %>">
      <%= image_tag "russ_live/keyvisuals/Keyvisual_RussLive2.jpg",
                    alt: "",
                    width: 9921,
                    height: 6260,
                    decoding: "async" %>
    </picture>

    <div class="team-hero-copy">
      <h1 id="team-title"><%= t("pages.team.hero.title") %></h1>
      <p><%= t("pages.team.hero.intro") %></p>
    </div>
  </section>

  <section class="public-section section team-section" aria-label="<%= t("pages.team.grid_aria") %>">
    <div class="team-grid">
      <% team_members.each do |member| %>
        <article class="team-card">
          <figure>
            <%= image_tag member[:image],
                          alt: member[:name],
                          loading: "lazy",
                          decoding: "async",
                          width: 600,
                          height: 600 %>
          </figure>
          <h2><%= member[:name] %></h2>
          <p><%= t("pages.team.members.#{member[:key]}.role") %></p>
        </article>
      <% end %>
    </div>
  </section>
</main>
