<main id="main-content" class="page-main public-page job-page" tabindex="-1" data-controller="job-filter">
  <section class="public-hero public-hero-dark section public-page-hero job-overview-hero" aria-labelledby="jobs-title">
    <div class="public-page-hero-media job-overview-hero-media">
      <%= image_tag @job_overview_hero_image,
                    alt: t("pages.jobs.hero.image_alt"),
                    width: 2565,
                    height: 1067,
                    decoding: "async",
                    fetchpriority: "high" %>
    </div>

    <div class="public-page-hero-copy job-overview-hero-copy">
      <h1 id="jobs-title">
        <span><%= t("pages.jobs.hero.title_first_line") %></span>
        <span><%= t("pages.jobs.hero.title_second_line") %></span>
      </h1>
      <p><%= t("pages.jobs.hero.intro") %></p>
      <%= public_backend_link(
            label: t("public.actions.edit"),
            path: backend_jobs_path,
            aria_label: t("public.actions.edit_jobs"),
            class_name: "public-button section-button section-button-outline-light public-admin-link",
            wrapper_class: "job-overview-hero-actions"
          ) %>
    </div>
  </section>

  <section class="public-section section job-overview-listing" id="jobs-list" aria-labelledby="jobs-list-title">
    <div class="job-overview-offers">
      <div class="job-overview-kicker">
        <p class="eyebrow"><%= t("pages.jobs.list.title") %></p>
        <h3 id="jobs-list-title"><%= t("pages.jobs.story.first_title") %></h3>
        <p><%= t("pages.jobs.story.first_text") %></p>
      </div>

      <div class="public-directory job-table" aria-label="<%= t("pages.jobs.list.aria") %>">
        <% @jobs.each do |job| %>
          <%= link_to job_path(job.slug), class: "public-card job-table-row", data: { job_categories: job.category_slugs.join(" ") } do %>
            <span class="job-table-position">
              <strong><%= job.title %></strong>
            </span>
            <span class="job-table-action">
              <span><%= t("jobs.list_action") %></span>
              <span aria-hidden="true">→</span>
            </span>
          <% end %>
        <% end %>
      </div>
    </div>
    <% if @jobs.empty? %>
      <p class="references-empty"><%= t("pages.jobs.empty") %></p>
    <% end %>

    <div class="job-story-band">
      <div class="job-story-band-copy">
        <p class="eyebrow"><%= t("pages.jobs.story.second_eyebrow") %></p>
        <h2><%= t("pages.jobs.story.second_title") %></h2>
        <p><%= t("pages.jobs.story.second_text") %></p>
      </div>
      <figure class="job-story-band-visual">
        <%= image_tag "russ_live/jobs/people-enjoying-music-concert.jpg",
                      alt: t("pages.jobs.story.crowd_image_alt"),
                      loading: "lazy",
                      decoding: "async",
                      width: 2200,
                      height: 1467 %>
      </figure>
    </div>
  </section>

  <section class="public-section section job-quotes-band" aria-label="<%= t("pages.jobs.quotes.aria") %>">
    <div class="job-quotes">
      <% t("pages.jobs.quotes.items").each_slice(2) do |quote_group| %>
        <blockquote class="job-quote job-quote-rotator">
          <% quote_group.each_with_index do |quote, quote_index| %>
            <span class="job-quote-slide job-quote-slide-<%= quote_index + 1 %>">
              <p><%= quote[:text] %></p>
              <footer><%= quote[:footer] %></footer>
            </span>
          <% end %>
        </blockquote>
      <% end %>
    </div>
  </section>

  <div class="job-overview-image-strip" aria-hidden="true">
    <% [
      "russ_live/jobs/stage-before.jpg",
      "russ_live/jobs/catering-team.jpg",
      "russ_live/jobs/forklift-driver.jpg",
      "russ_live/jobs/stagehand-crew.jpg",
      "russ_live/jobs/festival-leaflets.jpg",
      "russ_live/jobs/security-guard.jpg"
    ].each do |image| %>
      <span class="job-overview-image-strip-tile" style="--job-strip-image: url('<%= image_path image %>')"></span>
    <% end %>
  </div>
</main>
