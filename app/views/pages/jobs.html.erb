<main id="main-content" class="page-main public-page job-page" tabindex="-1" data-controller="job-filter">
  <section class="public-hero public-hero-dark section job-overview-hero" aria-labelledby="jobs-title">
    <div class="job-overview-hero-media">
      <%= image_tag @job_overview_hero_image,
                    alt: t("pages.jobs.hero.image_alt"),
                    width: 2565,
                    height: 1067,
                    decoding: "async",
                    fetchpriority: "high" %>
    </div>

    <div class="job-overview-hero-copy">
      <h1 id="jobs-title"><%= t("pages.jobs.hero.title") %></h1>
      <p><%= t("pages.jobs.hero.intro") %></p>
      <%= public_backend_link(
            label: t("public.actions.edit"),
            path: backend_jobs_path,
            aria_label: t("public.actions.edit_jobs"),
            class_name: "public-button section-button section-button-outline-light public-admin-link",
            wrapper_class: "job-overview-hero-actions"
          ) %>
    </div>
    <% if @job_categories.any? %>
      <nav class="public-filter-nav job-category-filter-nav" aria-label="<%= t("jobs.filters.aria") %>">
        <button type="button" data-job-category="all" aria-pressed="true"><%= t("public.filters.all") %></button>
        <% @job_categories.each do |job_category| %>
          <button type="button" data-job-category="<%= Job.category_slug(job_category) %>" aria-pressed="false"><%= job_category %></button>
        <% end %>
      </nav>
    <% end %>
  </section>

  <section class="public-section section job-overview-listing" id="jobs-list" aria-labelledby="jobs-list-title">
    <div class="job-overview-heading">
      <div>
        <h2 id="jobs-list-title"><%= t("pages.jobs.list.title") %></h2>
      </div>
    </div>

    <div class="public-directory job-table" role="table" aria-label="<%= t("pages.jobs.list.aria") %>">
      <div class="job-table-row job-table-row-head" role="row">
        <span role="columnheader"><%= t("pages.jobs.list.position") %></span>
        <span role="columnheader"><%= t("pages.jobs.list.category") %></span>
        <span role="columnheader"><%= t("pages.jobs.list.location") %></span>
        <span role="columnheader"><%= t("pages.jobs.list.inquiry") %></span>
      </div>

      <% @jobs.each do |job| %>
        <%= link_to job_path(job.slug), class: "public-card job-table-row", role: "row", data: { job_categories: job.category_slugs.join(" ") } do %>
          <span class="job-table-position" role="cell">
            <strong><%= job.title %></strong>
            <% if job.badge.present? %>
              <span class="job-table-badge"><%= job.badge %></span>
            <% end %>
          </span>
          <span role="cell"><%= job.category_list %></span>
          <span role="cell"><%= job.location %></span>
          <span class="job-table-action" role="cell">
            <span><%= t("jobs.apply_now") %></span>
            <span aria-hidden="true">→</span>
          </span>
        <% end %>
      <% end %>
    </div>
    <% if @jobs.empty? %>
      <p class="references-empty"><%= t("pages.jobs.empty") %></p>
    <% end %>
  </section>

  <section class="public-section section job-story-grid" id="jobs-story" aria-label="<%= t("pages.jobs.story.aria") %>">
    <article class="job-story-card">
      <figure class="job-story-image">
        <%= image_tag "russ_live/jobs/stage-before.jpg",
                      alt: t("pages.jobs.story.stage_image_alt"),
                      loading: "lazy",
                      decoding: "async",
                      width: 3827,
                      height: 2554 %>
      </figure>
      <div class="job-story-copy">
        <p class="eyebrow"><%= t("pages.jobs.story.first_eyebrow") %></p>
        <h2><%= t("pages.jobs.story.first_title") %></h2>
        <p><%= t("pages.jobs.story.first_text") %></p>
      </div>
    </article>

    <article class="job-story-band">
      <div class="job-story-band-copy">
        <p class="eyebrow"><%= t("pages.jobs.story.second_eyebrow") %></p>
        <h2><%= t("pages.jobs.story.second_title") %></h2>
        <p><%= t("pages.jobs.story.second_text") %></p>
      </div>
      <figure class="job-story-band-visual">
        <%= image_tag "russ_live/jobs/people-enjoying-music-concert.jpg",
                      alt: t("pages.jobs.story.crowd_image_alt"),
                      loading: "lazy",
                      decoding: "async",
                      width: 4200,
                      height: 2787 %>
      </figure>
    </article>

    <section class="job-quotes" aria-label="<%= t("pages.jobs.quotes.aria") %>">
      <% 3.times do %>
        <blockquote class="job-quote">
          <p><%= t("pages.jobs.quotes.text") %></p>
          <footer><%= t("pages.jobs.quotes.footer") %></footer>
        </blockquote>
      <% end %>
    </section>
  </section>
</main>
