<main class="page-main job-page">
      <section class="section job-hero" aria-labelledby="jobs-title">
        <div class="job-hero-copy">
          <p class="eyebrow">Jobs</p>
          <h1 id="jobs-title">Catering - hilfen</h1>
          <p>Zum nächstmöglichen Zeitpunkt, auf Minijob Basis, m/w/d</p>
          <a class="section-button" href="mailto:personal@russ-live.de">Jetzt bewerben</a>
        </div>
        <figure class="job-hero-media">
          <img src="<%= image_path "russ_live/jobs/cateringhilfen.jpg" %>" alt="Küchenteam bereitet frische Speisen zu">
        </figure>
      </section>

      <section class="section job-detail" aria-label="Jobdetails Cateringhilfen">
        <article class="job-content">
          <div class="job-section">
            <p class="eyebrow">Tätigkeitsfeld</p>
            <ul class="job-list">
              <li>Hilfstätigkeiten bei der Speisenzubereitung</li>
              <li>Auf- und Abbau von Buffets</li>
              <li>Unterstützung des Küchenteams</li>
            </ul>
          </div>

          <div class="job-section">
            <p class="eyebrow">Anforderungen</p>
            <ul class="job-list">
              <li>Zuverlässiges, gewissenhaftes Arbeiten</li>
              <li>Flexibilität auch spät abends oder nachts zu arbeiten</li>
              <li>Körperliche Fitness</li>
              <li>Team- und gute Kommunikationsfähigkeit</li>
              <li>Schnelle Auffassungsgabe</li>
              <li>Englischkenntnisse von Vorteil</li>
              <li>Motivation und Lust auf Arbeiten in der Event-Branche</li>
              <li>Gültiges allgemeines Gesundheitszeugnis</li>
            </ul>
          </div>

          <div class="job-apply">
            <h2>Wir freuen uns auf Deine Bewerbung!</h2>
            <a class="section-button" href="mailto:personal@russ-live.de">personal@russ-live.de</a>
          </div>
        </article>

        <aside class="job-sidebar" aria-label="Jobs und Ansprechpartner">
          <div class="job-nav">
            <p class="eyebrow">Jobs</p>
            <nav aria-label="Jobprofile">
              <a href="<%= jobs_path %>" aria-current="page">Cateringhilfen</a>
              <a href="<%= jobs_path %>">Stagehands</a>
              <a href="<%= jobs_path %>">Staplerfahrer*innen</a>
              <a href="<%= jobs_path %>">Securities</a>
            </nav>
          </div>

          <div class="job-contact">
            <p class="eyebrow">Ansprechpartner</p>
            <img src="<%= image_path "russ_live/team/sebastian-kraenzlein.jpg" %>" alt="Sebastian Kränzlein">
            <h2>Sebastian Kränzlein</h2>
            <p>Personaldisposition / Personalmarketing</p>
            <p><a href="tel:+497111635342">Telefon +49.711.16 353 42</a></p>
            <p><a href="mailto:sebastiankraenzlein@russ-live.de">sebastiankraenzlein@russ-live.de</a></p>
          </div>
        </aside>
      </section>
    </main>
