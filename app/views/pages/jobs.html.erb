<main id="main-content" class="page-main public-page job-page" tabindex="-1" data-controller="job-filter">
  <section class="public-hero public-hero-dark section job-overview-hero" aria-labelledby="jobs-title">
    <div class="job-overview-hero-media">
      <%= image_tag @job_overview_hero_image,
                    alt: "Backstage-Moment mit Russ Live Crew vor einer beleuchteten Bühne",
                    width: 2565,
                    height: 1067,
                    decoding: "async",
                    fetchpriority: "high" %>
    </div>

    <div class="job-overview-hero-copy">
      <h1 id="jobs-title">Werde Teil unseres Event-Teams.</h1>
      <p>Flexible Jobs bei Konzerten, Festivals und Events in Stuttgart.</p>
    </div>
    <% if @job_categories.any? %>
      <nav class="public-filter-nav job-category-filter-nav" aria-label="Jobs nach Bereichen filtern">
        <button type="button" data-job-category="all" aria-pressed="true">Alle</button>
        <% @job_categories.each do |job_category| %>
          <button type="button" data-job-category="<%= Job.category_slug(job_category) %>" aria-pressed="false"><%= job_category %></button>
        <% end %>
      </nav>
    <% end %>
  </section>

  <section class="public-section section job-overview-listing" id="jobs-list" aria-labelledby="jobs-list-title">
    <div class="job-overview-heading">
      <div>
        <h2 id="jobs-list-title">Unsere aktuellen Jobangebote</h2>
      </div>
    </div>

    <div class="public-directory job-table" role="table" aria-label="Jobangebote">
      <div class="job-table-row job-table-row-head" role="row">
        <span role="columnheader">Position</span>
        <span role="columnheader">Bereich</span>
        <span role="columnheader">Einsatzort</span>
        <span role="columnheader">Anfrage</span>
      </div>

      <% @jobs.each do |job| %>
        <%= link_to job_path(job.slug), class: "public-card job-table-row", role: "row", data: { job_categories: job.category_slugs.join(" ") } do %>
          <span class="job-table-position" role="cell">
            <strong><%= job.title %></strong>
            <% if job.badge.present? %>
              <span class="job-table-badge"><%= job.badge %></span>
            <% end %>
          </span>
          <span role="cell"><%= job.category_list %></span>
          <span role="cell"><%= job.location %></span>
          <span class="job-table-action" role="cell">
            <span>Jetzt bewerben</span>
            <span aria-hidden="true">→</span>
          </span>
        <% end %>
      <% end %>
    </div>
    <% if @jobs.empty? %>
      <p class="references-empty">Aktuell sind keine Jobs veröffentlicht.</p>
    <% end %>
  </section>

  <section class="public-section section job-story-grid" id="jobs-story" aria-label="Einblicke in die Arbeitswelt">
    <article class="job-story-card">
      <figure class="job-story-image">
        <%= image_tag "russ_live/jobs/stage-before.jpg",
                      alt: "Bühnenaufbau mit Traversen, Cases und Technik vor einem Event",
                      loading: "lazy",
                      decoding: "async",
                      width: 3827,
                      height: 2554 %>
      </figure>
      <div class="job-story-copy">
        <p class="eyebrow">Einzigartige Momente</p>
        <h2>Arbeiten, wo Events entstehen.</h2>
        <p>Vom ersten Aufbau bis zur letzten Show bist Du Teil eingespielter Teams und echter Live-Momente.</p>
      </div>
    </article>

    <article class="job-story-band">
      <div class="job-story-band-copy">
        <p class="eyebrow">Mehr als nur ein Job</p>
        <h2>Gemeinsam für unvergessliche Erlebnisse.</h2>
        <p>Wir arbeiten mit Leidenschaft, packen gemeinsam an und schaffen Events, die in Erinnerung bleiben.</p>
      </div>
      <figure class="job-story-band-visual">
        <%= image_tag "russ_live/jobs/people-enjoying-music-concert.jpg",
                      alt: "Publikum bei einem Konzert mit erhobenen Händen",
                      loading: "lazy",
                      decoding: "async",
                      width: 4200,
                      height: 2787 %>
      </figure>
    </article>

    <section class="job-quotes" aria-label="Stimmen aus dem Team">
      <% 3.times do %>
        <blockquote class="job-quote">
          <p>Man erlebt Events aus einer Perspektive, die sonst niemand sieht.</p>
          <footer>Luca, Stagehand seit 2022</footer>
        </blockquote>
      <% end %>
    </section>
  </section>
</main>
