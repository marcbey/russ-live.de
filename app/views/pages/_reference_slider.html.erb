<% slider_classes = local_assigns.fetch(:slider_classes, "klassik-slider") %>
<% show_meta = local_assigns.fetch(:show_meta, false) %>
<% flip_enabled = local_assigns.fetch(:flip_enabled, false) %>
<% link_slides = local_assigns.fetch(:link_slides, false) %>
<% button_label = local_assigns.fetch(:button_label, nil) %>
<% button_path = local_assigns.fetch(:button_path, nil) %>

<div class="<%= slider_classes %>" data-slider="" data-controller="slider">
  <div class="klassik-slider-viewport">
    <button class="klassik-slider-arrow klassik-slider-arrow-prev" type="button" aria-label="<%= t("references.slider.previous") %>">‹</button>
    <div class="klassik-slider-stage">
      <% references.each_with_index do |reference, index| %>
        <% reference_data = reference_home_card_data(reference) %>
        <% slide_data = {
             index: index,
             title: reference_data[:title],
             date_location: reference_data[:date_location],
             partner: reference_data[:partner]
           } %>
        <% slide_data[:link_url] = referenzen_path(reference_id: reference.id, anchor: "referenz-highlights") if link_slides %>
        <% slide_classes = ["klassik-slide"] %>
        <% slide_classes << "klassik-slide-flip" if flip_enabled %>
        <% slide_classes << "is-active" if index.zero? %>
        <% slide_classes << "is-next" if index == 1 %>
        <% slide_classes << "is-prev" if index == references.length - 1 %>
        <% slide_classes << "is-hidden" if index > 1 && index != references.length - 1 %>
        <% image_render_data = flip_enabled ? {} : reference_data[:image_render_data] %>
        <% frame_data = image_render_data.present? ? { reference_image_render_target: "frame" } : {} %>
        <%= tag.figure class: slide_classes.join(" "),
                       data: slide_data.merge(image_render_data).merge(frame_data),
                       tabindex: 0,
                       aria: { hidden: index.zero? ? "false" : "true", label: reference_data[:title] } do %>
          <% if flip_enabled %>
            <button class="klassik-slide-flip-button" type="button" aria-pressed="false" aria-label="<%= t("references.card.details_aria", title: reference.title) %>">
              <span class="klassik-slide-face klassik-slide-front" aria-hidden="true" data-reference-image-render-target="frame">
                <%= tag.img src: reference_data[:image],
                            alt: reference_data[:alt],
                            loading: index.zero? ? "eager" : "lazy",
                            decoding: "async",
                            width: reference_data.dig(:dimensions, :width),
                            height: reference_data.dig(:dimensions, :height),
                            style: reference_data[:image_style].presence,
                            data: { reference_image_render_target: "image" } %>
              </span>
              <span class="klassik-slide-face klassik-slide-back" style="background: #000;">
                <span class="reference-card-name"><%= reference.title %></span>
                <span class="reference-card-back-content">
                  <span class="reference-card-meta-group">
                    <span class="reference-card-meta reference-card-meta-plain"><%= reference_date_label(reference) %></span>
                    <span class="reference-card-meta reference-card-meta-plain"><%= reference.location %></span>
                  </span>
                  <% if reference.production.present? %>
                    <span class="reference-card-meta reference-card-meta-inline">
                      <strong><%= t("references.card.production") %></strong>
                      <span><%= reference.production %></span>
                    </span>
                  <% end %>
                  <% if reference.localized_description.present? %>
                    <span class="reference-card-copy"><%= reference.localized_description %></span>
                  <% end %>
                </span>
              </span>
            </button>
            <% if reference_data[:badge].present? %>
              <span class="klassik-slide-badge"><%= reference_data[:badge] %></span>
            <% end %>
          <% else %>
            <%= tag.img src: reference_data[:image],
                        alt: reference_data[:alt],
                        loading: index.zero? ? "eager" : "lazy",
                        decoding: "async",
                        width: reference_data.dig(:dimensions, :width),
                        height: reference_data.dig(:dimensions, :height),
                        style: reference_data[:image_style].presence,
                        data: { reference_image_render_target: "image" } %>
            <% if reference_data[:badge].present? %>
              <span class="klassik-slide-badge"><%= reference_data[:badge] %></span>
            <% end %>
          <% end %>
        <% end %>
      <% end %>
    </div>
    <button class="klassik-slider-arrow klassik-slider-arrow-next" type="button" aria-label="<%= t("references.slider.next") %>">›</button>
  </div>
  <% if button_label.present? && button_path.present? %>
    <div class="klassik-slider-footer">
      <%= link_to button_label, button_path, class: "public-button public-button-primary section-button klassik-slider-button" %>
    </div>
  <% end %>
  <% if show_meta %>
    <div class="klassik-slider-meta">
      <span class="klassik-slider-marker" aria-hidden="true"></span>
      <% first_reference_data = reference_home_card_data(references.first) %>
      <div class="klassik-slider-text">
        <h3><%= first_reference_data[:title] %></h3>
        <p class="klassik-slider-date-location"><%= first_reference_data[:date_location] %></p>
        <p class="klassik-slider-partner"><%= first_reference_data[:partner] %></p>
      </div>
      <div class="klassik-slider-actions">
        <a class="public-button public-button-primary section-button klassik-slider-button" href="<%= referenzen_path %>"><%= t("public.header.references") %></a>
        <%= public_backend_link(
              label: t("public.actions.edit"),
              path: backend_references_path,
              aria_label: t("public.actions.edit_references"),
              class_name: "public-button section-button public-admin-link klassik-slider-button"
            ) %>
      </div>
    </div>
  <% end %>
</div>
