<main id="main-content" class="page-main public-page press-detail-page" tabindex="-1">
  <section class="public-hero public-hero-detail section press-detail-hero" aria-labelledby="press-detail-title">
    <div class="press-detail-copy">
      <h1 id="press-detail-title"><%= @press_artist.name %></h1>
      <p><%= t("press.detail.intro", name: @press_artist.name) %></p>
      <div class="press-detail-actions">
        <%= link_to t("press.detail.back"), presse_path(anchor: "press-search"), class: "press-back-link" %>
        <% if @press_artist.gallery_images.any? %>
          <%= link_to t("press.detail.download_presskit"), press_artist_download_path(@press_artist.slug), class: "public-button public-button-outline press-outline-button", data: { turbo: false } %>
        <% end %>
      </div>
    </div>
    <figure class="press-detail-image">
      <% hero_image = @press_artist.hero_image %>
      <% if hero_image.is_a?(EventImage) %>
        <picture>
          <source media="(max-width: 700px)" srcset="<%= url_for hero_image.press_variant(:hero_mobile) %>">
          <%= image_tag hero_image.press_variant(:hero_desktop),
                        alt: hero_image.alt_text.presence || t("press.detail.press_photo_alt", name: @press_artist.name),
                        decoding: "async",
                        fetchpriority: "high" %>
        </picture>
        <% if (hero_credit = press_image_credit(hero_image)).present? %>
          <figcaption><%= hero_credit %></figcaption>
        <% end %>
      <% else %>
        <%= image_tag hero_image, alt: t("press.detail.press_photo_alt", name: @press_artist.name), decoding: "async", fetchpriority: "high" %>
      <% end %>
    </figure>
  </section>

  <section class="public-section section press-detail-content" aria-label="<%= t("press.detail.info_aria") %>">
    <article class="press-text-panel">
      <p class="eyebrow"><%= t("press.detail.press_text.eyebrow") %></p>
      <h2><%= @press_artist.name %></h2>
      <% if @press_artist.press_body.present? %>
        <%= @press_artist.press_body.respond_to?(:to_trix_html) ? @press_artist.press_body : simple_format(@press_artist.press_body) %>
      <% else %>
        <p><%= t("press.detail.press_text.empty") %></p>
      <% end %>
      <p><%= t("press.detail.press_text.usage") %></p>
    </article>
    <aside class="press-event-panel">
      <p class="eyebrow"><%= t("press.detail.event.eyebrow") %></p>
      <dl>
        <% primary_event = @press_artist.primary_event %>
        <% primary_event_current = primary_event.start_at.future? %>
        <div><dt><%= t("press.detail.event.date") %></dt><dd><%= l(primary_event.start_at.to_date, format: "%d. %B %Y") %></dd></div>
        <div><dt><%= t("press.detail.event.time") %></dt><dd><%= l(primary_event.start_at, format: t("time.formats.event_time")) %></dd></div>
        <% if primary_event.venue.present? %>
          <div><dt><%= t("press.detail.event.location") %></dt><dd><%= primary_event.venue %></dd></div>
        <% end %>
        <div><dt><%= t("press.detail.event.status") %></dt><dd><%= primary_event_current ? t("press.detail.event.current") : t("press.detail.event.past") %></dd></div>
        <% if @press_artist.additional_events.any? %>
          <div>
            <dt><%= t("press.detail.event.more_dates") %></dt>
            <dd>
              <% @press_artist.additional_events.each do |event| %>
                <span><%= l(event.start_at.to_date, format: "%d.%m.%Y") %><%= " · #{event.venue}" if event.venue.present? %></span><br>
              <% end %>
            </dd>
          </div>
        <% end %>
      </dl>
      <% if primary_event_current %>
        <a class="public-button public-button-primary section-button press-event-ticket-button" href="<%= @press_artist.ticket_url %>" target="_blank" rel="noreferrer"><%= t("events.tickets") %></a>
      <% end %>
    </aside>
  </section>

  <% if @press_artist.gallery_images.any? %>
    <section class="public-section section press-downloads" id="downloads" aria-labelledby="press-download-title" data-controller="press-lightbox" data-press-lightbox-fallback-alt-value="<%= t("press.detail.fallback_image_alt") %>">
      <div class="press-directory-head">
        <div>
          <p class="eyebrow"><%= t("press.detail.downloads.eyebrow") %></p>
          <h2 id="press-download-title"><%= t("press.detail.downloads.title") %></h2>
        </div>
      </div>
      <div class="public-media-grid press-gallery" data-press-gallery>
        <% @press_artist.gallery_images.each_with_index do |image, index| %>
          <% label = image.alt_text.presence || t("press.detail.gallery_image_label", name: @press_artist.name, index: index + 1) %>
          <% credit = press_image_credit(image) %>
          <% download_url = rails_blob_path(image.file, disposition: "attachment") %>
          <figure>
            <button type="button" data-press-lightbox-target="trigger" data-lightbox-src="<%= url_for image.press_variant(:hero_desktop) %>" data-lightbox-download="<%= download_url %>" data-lightbox-alt="<%= label %>" data-lightbox-caption="<%= credit %>" data-action="press-lightbox#open">
              <picture>
                <source media="(max-width: 700px)" srcset="<%= url_for image.press_variant(:gallery_mobile) %>">
                <%= image_tag image.press_variant(:gallery_desktop), alt: label, loading: "lazy", decoding: "async" %>
              </picture>
            </button>
            <figcaption>
              <% if credit.present? %>
                <span><%= credit %></span>
              <% end %>
              <%= link_to download_url, download: true, class: "press-gallery-download", aria: { label: t("press.detail.download_image") } do %>
                <span class="sr-only"><%= t("press.detail.download_image") %></span>
                <svg aria-hidden="true" viewBox="0 0 24 24" focusable="false">
                  <path d="M12 3v11m0 0 4-4m-4 4-4-4M5 17v3h14v-3" />
                </svg>
              <% end %>
            </figcaption>
          </figure>
        <% end %>
      </div>
      <div class="press-download-actions press-download-actions-footer">
        <%= link_to t("press.detail.download_presskit"), press_artist_download_path(@press_artist.slug), class: "public-button public-button-primary section-button", data: { turbo: false } %>
        <%= link_to t("press.detail.back"), presse_path(anchor: "press-search"), class: "public-button section-button press-download-back-button" %>
      </div>

      <div class="press-lightbox" data-press-lightbox-target="lightbox" hidden>
        <div class="press-lightbox-dialog" role="dialog" aria-modal="true" aria-label="<%= t("press.detail.lightbox_aria") %>">
          <button class="press-lightbox-close" type="button" data-press-lightbox-target="close" data-action="press-lightbox#close" aria-label="<%= t("press.detail.close_lightbox") %>">×</button>
          <button class="press-lightbox-arrow press-lightbox-prev" type="button" data-action="press-lightbox#previous" aria-label="<%= t("press.detail.previous_image") %>">‹</button>
          <figure>
            <img src="" alt="" data-press-lightbox-target="image">
            <figcaption>
              <span data-press-lightbox-target="caption"></span>
              <a href="#" download data-press-lightbox-target="download" class="press-gallery-download" aria-label="<%= t("press.detail.download_image") %>">
                <span class="sr-only"><%= t("press.detail.download_image") %></span>
                <svg aria-hidden="true" viewBox="0 0 24 24" focusable="false">
                  <path d="M12 3v11m0 0 4-4m-4 4-4-4M5 17v3h14v-3" />
                </svg>
              </a>
            </figcaption>
          </figure>
          <button class="press-lightbox-arrow press-lightbox-next" type="button" data-action="press-lightbox#next" aria-label="<%= t("press.detail.next_image") %>">›</button>
        </div>
      </div>
    </section>
  <% end %>

  <%= render "pages/press_contact", title_id: "press-detail-contact-title" %>
</main>
