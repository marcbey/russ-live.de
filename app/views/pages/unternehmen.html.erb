<% company_areas = [
  {
    key: "klassik",
    logo: "russ_live/about/russ-klassik-logo.png",
    title: "Russ Klassik",
    url: "https://russ-klassik.de/",
    text: t("pages.about.company.areas.klassik")
  },
  {
    key: "live",
    logo: "russ_live/about/russ-live-area-logo.png",
    title: "Russ Live",
    url: "https://www.michaelrussgmbh.de/",
    text: t("pages.about.company.areas.live")
  },
  {
    key: "artists",
    logo: "russ_live/about/russ-artists-logo.png",
    title: "Russ Artists",
    url: "https://russ-artists.de/",
    text: t("pages.about.company.areas.artists")
  },
  {
    key: "service",
    logo: "russ_live/about/russ-service-logo.png",
    title: "Russ Service",
    url: "https://www.ordnerdienste-stuttgart.de/",
    text: t("pages.about.company.areas.service")
  }
] %>

<main id="main-content" class="page-main public-page about-page" tabindex="-1">
  <section class="public-hero public-hero-editorial section about-hero" aria-labelledby="about-title">
    <div class="about-hero-copy">
      <h1 id="about-title">
        <span><%= t("pages.about.hero.title_lines.people") %></span>
        <span><em><%= t("pages.about.hero.title_lines.moments") %></em></span>
        <span><%= t("pages.about.hero.title_lines.since") %></span>
      </h1>
      <p><%= t("pages.about.hero.intro") %></p>
    </div>

    <div class="about-hero-collage" aria-hidden="true">
      <figure class="about-hero-card about-hero-card-tall">
        <%= image_tag "russ_live/about/tina-turner-1990.jpg", alt: "", width: 1264, height: 1772, decoding: "async" %>
      </figure>
      <figure class="about-hero-card about-hero-card-wide">
        <%= image_tag "russ_live/about/u2-2002.jpg", alt: "", width: 600, height: 400, decoding: "async" %>
      </figure>
      <figure class="about-hero-card about-hero-card-square">
        <%= image_tag "russ_live/about/ike-tina-1971.jpg", alt: "", width: 1408, height: 792, decoding: "async" %>
      </figure>
    </div>
  </section>

  <section class="public-section section about-story-lead" aria-labelledby="about-story-lead-title">
    <div class="about-story-lead-copy">
      <h2 id="about-story-lead-title" class="sr-only"><%= t("pages.about.profile_title") %></h2>
      <p><%= t("pages.about.story.first_html") %></p>
      <p><%= t("pages.about.story.second_html") %></p>
    </div>
  </section>

  <section class="public-section section about-history-section about-history-section-first" aria-labelledby="about-history-title">
    <figure class="about-history-image about-history-image-portrait">
      <%= image_tag "russ_live/about/geschichte-v2.jpg",
                    alt: t("pages.about.history.image_alt"),
                    loading: "lazy",
                    decoding: "async",
                    width: 1200,
                    height: 675 %>
    </figure>

    <div class="about-history-copy">
      <h2 id="about-history-title"><%= t("pages.about.history.title") %></h2>
      <p><%= t("pages.about.history.first") %></p>
      <p><%= t("pages.about.history.second") %></p>
    </div>
  </section>

  <section class="public-section about-company-band" aria-labelledby="about-company-band-title">
    <div class="about-company-band-copy">
      <h2 id="about-company-band-title"><%= t("pages.about.company.title_html") %></h2>
    </div>

    <div class="about-company-band-grid">
      <% (company_areas + company_areas).each_with_index do |area, index| %>
        <% duplicate = index >= company_areas.length %>
        <article class="public-card about-company-card about-company-card-<%= area[:key] %><%= " about-company-card-duplicate" if duplicate %>"<%= " aria-hidden=\"true\"".html_safe if duplicate %>>
          <a href="<%= area[:url] %>" target="_blank" rel="noopener noreferrer" aria-label="<%= t("pages.about.company.open_aria", title: area[:title]) %>"<%= " tabindex=\"-1\"".html_safe if duplicate %>>
            <figure class="about-company-logo">
              <%= image_tag area[:logo], alt: area[:title] %>
            </figure>
            <div class="about-company-hover-copy">
              <h3><%= area[:title] %></h3>
              <p><%= area[:text] %></p>
            </div>
          </a>
        </article>
      <% end %>
    </div>
  </section>

  <section class="public-section section about-editorial-section" aria-labelledby="about-award-title">
    <div class="about-editorial-visuals" aria-hidden="true">
      <figure class="about-editorial-image about-editorial-image-founder">
        <%= image_tag "russ_live/about/michael-michaela.jpg",
                      alt: "",
                      loading: "lazy",
                      decoding: "async",
                      width: 857,
                      height: 785 %>
      </figure>

      <figure class="about-editorial-image about-editorial-image-team">
        <%= image_tag "russ_live/about/paul-michi.jpg",
                      alt: "",
                      loading: "lazy",
                      decoding: "async",
                      width: 1122,
                      height: 879 %>
      </figure>
    </div>

    <div class="about-editorial-copy">
      <article class="about-editorial-block">
        <h2 id="about-award-title"><%= t("pages.about.award.title") %></h2>
        <p><%= t("pages.about.award.first") %></p>
      </article>

      <article class="about-editorial-block">
        <h2 id="about-city-title"><%= t("pages.about.city.title") %></h2>
        <p><%= t("pages.about.city.first") %></p>
        <p><%= t("pages.about.city.second") %></p>
      </article>

      <article class="about-editorial-block about-editorial-block-closing">
        <p><%= t("pages.about.closing.text") %></p>
        <% t("pages.about.closing.placeholder_paragraphs").each do |paragraph| %>
          <p><%= paragraph %></p>
        <% end %>
      </article>
    </div>
  </section>

  <section class="about-quote-band" aria-labelledby="about-quote-title">
    <h2 id="about-quote-title">
      <span aria-hidden="true">»</span>
      <%= t("pages.about.closing.title") %>
      <span aria-hidden="true">«</span>
    </h2>
  </section>
</main>
