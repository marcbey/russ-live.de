<% company_areas = [
  {
    key: "live",
    logo: "russ_live/about/russ-live-area-logo.png",
    title: "Russ Live",
    url: "https://www.michaelrussgmbh.de/",
    text: "Ob Club- oder Stadion-Konzerte, Musicals, Shows oder ihr nächstes Firmenevent. Wir sind ihr starker Partner."
  },
  {
    key: "artists",
    logo: "russ_live/about/russ-artists-logo.png",
    title: "Russ Artists",
    url: "https://russ-artists.de/",
    text: "Ihr engagierter Partner bei der Suche nach Künstlern und Programmen, die Ihrem Veranstalterprofil entsprechen."
  },
  {
    key: "service",
    logo: "russ_live/about/russ-service-logo.png",
    title: "Russ Service",
    url: "https://www.ordnerdienste-stuttgart.de/",
    text: "Wir sorgen für eine sichere Veranstaltung: Konzert, Tagung, Firmenfeier oder Konferenz."
  },
  {
    key: "klassik",
    logo: "russ_live/about/russ-klassik-logo.png",
    title: "Russ Klassik",
    url: "https://russ-klassik.de/",
    text: "Entdecken Sie bei uns die faszinierende Welt der klassischen Musik. Meisterkonzerte für Stuttgart. Seit 1945."
  }
] %>

<main id="main-content" class="page-main public-page about-page" tabindex="-1">
  <section class="public-hero public-hero-editorial section about-hero" aria-labelledby="about-title">
    <div class="about-hero-copy">
      <p class="eyebrow">Über uns</p>
      <h1 id="about-title">
        <span>Menschen.</span>
        <span><em>Momente.</em></span>
        <span>Seit 1945.</span>
      </h1>
      <p>Aus Stuttgart. Für die Welt. Seit drei Generationen gestalten wir Konzerte, die verbinden.</p>
    </div>

    <div class="about-hero-collage" aria-hidden="true">
      <figure class="about-hero-card about-hero-card-tall">
        <%= image_tag "russ_live/about/tina-turner-1990.jpg", alt: "", width: 1264, height: 1772, decoding: "async" %>
      </figure>
      <figure class="about-hero-card about-hero-card-wide">
        <%= image_tag "russ_live/about/u2-2002.jpg", alt: "", width: 600, height: 400, decoding: "async" %>
      </figure>
      <figure class="about-hero-card about-hero-card-square">
        <%= image_tag "russ_live/about/ike-tina-1971.jpg", alt: "", width: 1408, height: 792, decoding: "async" %>
      </figure>
    </div>
  </section>

  <section class="public-section section about-story-lead" aria-labelledby="about-story-lead-title">
    <div class="about-story-lead-copy">
      <h2 id="about-story-lead-title" class="sr-only">Unternehmensprofil</h2>
      <p><strong>Michael Russ Jr.</strong> ist mit einer ruhigen Nähe, viel Herz und echtem Unternehmergeist auf die Welt von Russ Live gewachsen. Im Laufe der Jahre wurde daraus Verantwortung, Erfahrung und ein klarer Blick dafür, wie man Kultur dauerhaft möglich macht.</p>
      <p><strong>Michaela Russ</strong> führt diesen Weg in der dritten Generation weiter. Gemeinsam steht die Familie für Produktionen, die professionell organisiert sind und trotzdem menschlich bleiben. Daraus ist ein Team entstanden, das Kultur mit Haltung, Verlässlichkeit und Leidenschaft umsetzt.</p>
    </div>
  </section>

  <section class="public-section about-company-band" aria-labelledby="about-company-band-title">
    <div class="about-company-band-copy">
      <p class="eyebrow">Konzertdirektion Russ</p>
      <h2 id="about-company-band-title">Vier Unternehmen.<br>Eine Vision.</h2>
      <p>Wir wollen Menschen glücklich machen.</p>
      <%= link_to "Konzertdirektion", "https://www.konzertdirektion-russ.de/", class: "public-button public-button-primary section-button about-company-band-button", target: "_blank", rel: "noopener noreferrer" %>
    </div>

    <div class="about-company-band-grid">
      <% company_areas.each do |area| %>
        <article class="public-card about-company-card about-company-card-<%= area[:key] %>">
          <a href="<%= area[:url] %>" target="_blank" rel="noopener noreferrer" aria-label="<%= "#{area[:title]} öffnen" %>">
            <figure class="about-company-logo">
              <%= image_tag area[:logo], alt: area[:title] %>
            </figure>
            <div class="about-company-hover-copy">
              <h3><%= area[:title] %></h3>
              <p><%= area[:text] %></p>
            </div>
          </a>
        </article>
      <% end %>
    </div>
  </section>

  <section class="public-section section about-history-section about-history-section-first" aria-labelledby="about-history-title">
    <figure class="about-history-image about-history-image-portrait">
      <%= image_tag "russ_live/about/geschichte-v2.jpg",
                    alt: "Michaela Russ, Michael Russ und ein historisches Familienportrait",
                    loading: "lazy",
                    decoding: "async",
                    width: 1200,
                    height: 675 %>
    </figure>

    <div class="about-history-copy">
      <p class="eyebrow">Geschichte</p>
      <h2 id="about-history-title">Unsere Geschichte. Drei Generationen. Eine Haltung.</h2>
      <p>Was 1945 mit einer Vision begann, ist heute eine der führenden Konzertdirektionen Europas. Von Stuttgart aus hat Russ über Jahrzehnte Konzertgeschichte mitgeprägt und sich gleichzeitig die Nähe zur Region bewahrt.</p>
      <p>Diese Verbindung aus lokaler Verwurzelung und internationalem Anspruch prägt unseren Blick bis heute: Wir denken groß, arbeiten partnerschaftlich und behalten immer die Menschen hinter jeder Produktion im Fokus.</p>
    </div>
  </section>

  <section class="public-section section about-history-section about-history-section-award" aria-labelledby="about-award-title">
    <div class="about-history-copy about-history-copy-narrow">
      <p class="eyebrow">Verantwortung</p>
      <h2 id="about-award-title">Erfahrung, die nicht stillsteht.</h2>
      <p>Ob Tournee, Einzelshow, Kulturformat oder Großereignis: Wir verbinden gewachsene Branchenkenntnis mit dem Anspruch, uns immer weiterzuentwickeln. Genau daraus entsteht die Mischung aus Präzision, Ruhe und Neugier, die unsere Arbeit auszeichnet.</p>
      <p>Auszeichnungen freuen uns. Wichtiger ist uns aber, dass Künstler, Publikum, Partner und Teams sich auf uns verlassen können.</p>
    </div>

    <figure class="about-history-image about-history-image-award">
      <%= image_tag "russ_live/about/award-top-magazin.jpg",
                    alt: "Michael Russ Jr. mit Auszeichnung und Partner bei einer Preisverleihung",
                    loading: "lazy",
                    decoding: "async",
                    width: 3661,
                    height: 5491 %>
    </figure>
  </section>

  <section class="public-section section about-history-section about-history-section-city" aria-labelledby="about-city-title">
    <div class="about-city-visuals">
      <figure class="about-history-image about-history-image-small">
        <%= image_tag "russ_live/about/ike-tina-1971.jpg",
                      alt: "Historisches Konzertfoto von Ike und Tina Turner",
                      loading: "lazy",
                      decoding: "async",
                      width: 1408,
                      height: 792 %>
      </figure>
      <figure class="about-history-image about-history-image-large">
        <%= image_tag "russ_live/about/adac-2003.jpg",
                      alt: "Großveranstaltung in Stuttgart mit Oldtimer-Korso",
                      loading: "lazy",
                      decoding: "async",
                      width: 3008,
                      height: 2000 %>
      </figure>
    </div>

    <div class="about-history-copy">
      <p class="eyebrow">Perspektive</p>
      <h2 id="about-city-title">Von Stuttgart in die Welt.</h2>
      <p>Ob in der Stuttgarter Liederhalle, auf den großen Festivalflächen, in Arenen oder Open-Air-Produktionen: Wir bringen Menschen zusammen. Live. Echt. Unvergesslich.</p>
      <p>Die Stadt ist unser Ausgangspunkt, nicht unsere Grenze. Aus ihr heraus entwickeln wir Formate, die regional verankert sind und weit darüber hinaus wirken.</p>
    </div>
  </section>

  <section class="public-section about-closing section" aria-labelledby="about-closing-title">
    <div class="about-closing-copy">
      <p class="eyebrow">Heute</p>
      <h2 id="about-closing-title">Tradition ist für uns kein Rückblick, sondern Vertrauen in das, was als Nächstes kommt.</h2>
      <p>Russ Live steht für Erfahrung ohne Stillstand, für Qualität ohne Attitüde und für Produktionen, die Kultur als gemeinsame Aufgabe begreifen.</p>
    </div>
  </section>
</main>
