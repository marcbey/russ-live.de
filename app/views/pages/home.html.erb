<main id="main-content" class="page-main public-page home-page" tabindex="-1">
      <section class="public-hero public-hero-dark home-hero" aria-labelledby="hero-title">
        <picture class="home-hero-media">
          <source media="(max-width: 900px)" srcset="<%= image_path "russ_live/keyvisuals/Keyvisual_RussLive_hoch_mobil.jpg" %>">
          <%= image_tag "russ_live/keyvisuals/Keyvisual_RussLive2.jpg",
                        alt: t("pages.home.hero.image_alt"),
                        width: 9921,
                        height: 6260,
                        decoding: "async",
                        fetchpriority: "high" %>
        </picture>
        <div class="home-hero-copy">
          <h1 id="hero-title"><span>Live</span><span>Enter</span><span>Tainment</span></h1>
          <p id="hero-intro"><%= t("pages.home.hero.intro") %></p>
          <a class="public-button public-button-primary hero-button home-hero-button" href="#services" data-anchor-position="flush"><%= t("public.header.services") %></a>
        </div>
      </section>

      <section class="public-section section services-preview" id="services" aria-labelledby="services-title">
        <div class="section-aside">
          <p class="eyebrow"><%= t("pages.home.services.eyebrow") %></p>
          <h2 id="services-title"><%= t("pages.home.services.title") %></h2>
          <p><%= t("pages.home.services.intro") %></p>
        </div>
        <div class="services-accordion-wrap">
          <div class="accordion" id="services-accordion" data-controller="accordion">
<article class="accordion-item">
              <button class="accordion-trigger" type="button" aria-expanded="false">
                <span><%= t("services.items.local.title") %></span>
                <span class="accordion-icon" aria-hidden="true">+</span>
              </button>
              <div class="accordion-panel">
                <div class="accordion-panel-inner">
                  <p><%= t("services.items.local.paragraphs.first") %></p>
                  <p><%= t("services.items.local.paragraphs.second") %></p>
                  <p><%= t("pages.home.services.local_partners") %></p>
                </div>
              </div>
            </article>
<article class="accordion-item">
              <button class="accordion-trigger" type="button" aria-expanded="false">
                <span><%= t("services.items.production.title") %></span>
                <span class="accordion-icon" aria-hidden="true">+</span>
              </button>
              <div class="accordion-panel">
                <div class="accordion-panel-inner">
                  <p><%= t("services.items.production.paragraphs.first") %></p>
                  <p><%= t("services.items.production.paragraphs.second") %></p>
                  <p><%= t("pages.home.services.production_contact_html") %></p>
                </div>
              </div>
            </article>
<article class="accordion-item">
              <button class="accordion-trigger" type="button" aria-expanded="false">
                <span><%= t("services.items.marketing.title") %></span>
                <span class="accordion-icon" aria-hidden="true">+</span>
              </button>
              <div class="accordion-panel">
                <div class="accordion-panel-inner">
                  <p><%= t("services.items.marketing.paragraphs.first") %></p>
                  <p><%= t("pages.home.services.marketing_contact_html") %></p>
                  <p><%= t("pages.home.services.legal_links_html") %></p>
                </div>
              </div>
            </article>
<article class="accordion-item">
              <button class="accordion-trigger" type="button" aria-expanded="false">
                <span><%= t("services.items.staff.title") %></span>
                <span class="accordion-icon" aria-hidden="true">+</span>
              </button>
              <div class="accordion-panel">
                <div class="accordion-panel-inner">
                  <p><%= t("services.items.staff.paragraphs.first") %></p>
                  <p><%= t("services.items.staff.paragraphs.second") %></p>
                  <p><%= t("pages.home.services.staff_equal_opportunity") %></p>
                </div>
              </div>
            </article>
<article class="accordion-item">
              <button class="accordion-trigger" type="button" aria-expanded="false">
                <span><%= t("services.items.ticketing.title") %></span>
                <span class="accordion-icon" aria-hidden="true">+</span>
              </button>
              <div class="accordion-panel">
                <div class="accordion-panel-inner">
                  <p><%= t("services.items.ticketing.paragraphs.first") %></p>
                  <p><%= t("services.items.ticketing.paragraphs.second") %></p>
                </div>
              </div>
            </article>
          </div>
          <a class="public-button public-button-primary section-button" href="<%= services_path %>"><%= t("public.header.services") %></a>
        </div>
      </section>

      <% if @home_references.any? %>
        <section class="public-section section references-band home-references-band" id="referenzen" aria-labelledby="references-title">
          <div class="section-head">
            <p class="eyebrow"><%= t("public.header.references") %></p>
            <h2 id="references-title"><%= t("pages.home.references.title") %></h2>
          </div>
          <%= render "pages/reference_slider",
                     references: @home_references,
                     link_slides: true,
                     button_label: t("pages.home.references.show_all"),
                     button_path: referenzen_path %>
        </section>
      <% end %>

      <% if @home_events.any? %>
      <section class="public-section section home-events" aria-labelledby="events-title" data-controller="events-slider" data-events-slider-url-value="<%= homepage_lane_events_path %>" data-events-slider-cursor-value="<%= @home_events_next_cursor %>">
        <div class="section-head home-events-head">
          <div>
            <p class="eyebrow"><%= t("pages.home.events.eyebrow") %></p>
            <h2 id="events-title"><%= t("pages.home.events.title") %></h2>
            <p class="home-events-intro"><%= t("pages.home.events.intro") %></p>
          </div>
          <div class="home-events-toolbar">
            <a class="public-button public-button-primary button home-events-all-button" href="<%= @stuttgart_live_sks_highlights_url %>" target="_blank" rel="noreferrer"><%= t("pages.home.events.show_all") %></a>
          </div>
        </div>

        <div class="home-events-viewport">
          <div class="home-events-nav" aria-label="<%= t("pages.home.events.nav_aria") %>">
            <button class="home-events-nav-button" type="button" data-action="events-slider#previous" aria-label="<%= t("pages.home.events.previous") %>">‹</button>
            <button class="home-events-nav-button" type="button" data-action="events-slider#next" aria-label="<%= t("pages.home.events.next") %>">›</button>
          </div>
          <div class="home-events-slider" aria-label="<%= t("pages.home.events.title") %>" data-events-slider-target="viewport">
            <%= render "pages/event_slider_cards", events: @home_events %>
          </div>
        </div>
        <a class="public-text-link home-events-link" href="<%= @stuttgart_live_sks_highlights_url %>" target="_blank" rel="noreferrer"><%= t("pages.home.events.all_events") %></a>
      </section>
      <% end %>
    </main>
