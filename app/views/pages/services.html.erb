<main id="main-content" class="page-main public-page services-page" tabindex="-1">
      <section class="public-hero public-hero-dark services-hero" aria-labelledby="services-title">
        <div class="services-hero-media">
          <%= image_tag "russ_live/keyvisuals/services-festival-hero.jpg",
                        alt: t("pages.services.hero.image_alt"),
                        width: 1920,
                        height: 1280,
                        decoding: "async",
                        fetchpriority: "high" %>
        </div>
        <div class="services-hero-copy">
          <h1 id="services-title">
            <span>Alles was</span>
            <span>ein Live Event</span>
            <span>braucht</span>
          </h1>
          <p><%= t("pages.services.hero.intro") %></p>
        </div>
      </section>

      <section class="service-chapters" aria-label="<%= t("pages.services.details_aria") %>">
<article class="service-chapter" id="local">
          <h2><%= t("services.items.local.title") %></h2>
          <div class="service-chapter-copy">
            <p><%= t("services.items.local.paragraphs.first") %></p>
            <p><%= t("services.items.local.paragraphs.second") %></p>
            <p class="service-contact-heading"><%= t("pages.services.contacts.aria") %></p>
            <div class="service-contact-grid" aria-label="<%= t("pages.services.contacts.aria") %>">
              <article class="service-contact-card">
                <%= image_tag "russ_live/team/paul-woog.jpg",
                              alt: t("pages.services.contacts.paul.name"),
                              loading: "lazy",
                              decoding: "async",
                              width: 1024,
                              height: 1024 %>
                <div class="service-contact-meta">
                  <h3><%= t("pages.services.contacts.paul.name") %></h3>
                  <p><%= t("pages.services.contacts.paul.role") %></p>
                  <p><%= mail_to t("pages.services.contacts.paul.email"), t("pages.services.contacts.paul.email") %></p>
                </div>
              </article>
              <article class="service-contact-card">
                <%= image_tag "russ_live/team/johanna-backmund.jpg",
                              alt: t("pages.services.contacts.johanna.name"),
                              loading: "lazy",
                              decoding: "async",
                              width: 1024,
                              height: 1024 %>
                <div class="service-contact-meta">
                  <h3><%= t("pages.services.contacts.johanna.name") %></h3>
                  <p><%= t("pages.services.contacts.johanna.role") %></p>
                  <p><%= mail_to t("pages.services.contacts.johanna.email"), t("pages.services.contacts.johanna.email") %></p>
                </div>
              </article>
            </div>
          </div>
          <figure class="public-card service-chapter-visual service-chapter-visual-filled">
            <%= image_tag "russ_live/keyvisuals/services-local.jpg",
                          alt: "",
                          width: 8643,
                          height: 4862,
                          loading: "lazy",
                          decoding: "async" %>
          </figure>
        </article>

<article class="service-chapter service-chapter-reverse" id="production">
          <h2><%= t("services.items.production.title") %></h2>
          <div class="service-chapter-copy">
            <p><%= t("services.items.production.paragraphs.first") %></p>
            <p><%= t("services.items.production.paragraphs.second") %></p>
            <p class="service-contact-heading"><%= t("pages.services.contacts.aria") %></p>
            <div class="service-contact-grid" aria-label="<%= t("pages.services.contacts.aria") %>">
              <article class="service-contact-card">
                <%= image_tag "russ_live/team/paul-woog.jpg",
                              alt: t("pages.services.contacts.paul.name"),
                              loading: "lazy",
                              decoding: "async",
                              width: 1024,
                              height: 1024 %>
                <div class="service-contact-meta">
                  <h3><%= t("pages.services.contacts.paul.name") %></h3>
                  <p><%= t("pages.services.contacts.paul.role") %></p>
                  <p><%= mail_to t("pages.services.contacts.paul.email"), t("pages.services.contacts.paul.email") %></p>
                </div>
              </article>
            </div>
          </div>
          <figure class="public-card service-chapter-visual service-chapter-visual-filled">
            <%= image_tag "russ_live/keyvisuals/services-production.jpg",
                          alt: "",
                          width: 5352,
                          height: 3568,
                          loading: "lazy",
                          decoding: "async" %>
          </figure>
        </article>

<article class="service-chapter" id="marketing">
          <h2><%= t("services.items.marketing.title") %></h2>
          <div class="service-chapter-copy">
            <p><%= t("services.items.marketing.paragraphs.first") %></p>
            <p class="service-contact-heading"><%= t("pages.services.contacts.aria") %></p>
            <div class="service-contact-grid" aria-label="<%= t("pages.services.contacts.aria") %>">
              <article class="service-contact-card">
                <%= image_tag "russ_live/team/sarah-sandner.jpg",
                              alt: t("pages.services.contacts.sarah.name"),
                              loading: "lazy",
                              decoding: "async",
                              width: 1024,
                              height: 1024 %>
                <div class="service-contact-meta">
                  <h3><%= t("pages.services.contacts.sarah.name") %></h3>
                  <p><%= t("pages.services.contacts.sarah.role") %></p>
                  <p><%= mail_to t("pages.services.contacts.sarah.email"), t("pages.services.contacts.sarah.email") %></p>
                </div>
              </article>
            </div>
          </div>
          <figure class="public-card service-chapter-visual service-chapter-visual-filled">
            <%= image_tag "russ_live/keyvisuals/services-marketing.jpg",
                          alt: "",
                          width: 1800,
                          height: 1200,
                          loading: "lazy",
                          decoding: "async" %>
          </figure>
        </article>

<article class="service-chapter service-chapter-reverse" id="staff">
          <h2><%= t("services.items.staff.title") %></h2>
          <div class="service-chapter-copy">
            <p><%= t("services.items.staff.paragraphs.first") %></p>
            <p><%= t("services.items.staff.paragraphs.second") %></p>
            <p class="service-contact-heading"><%= t("pages.services.contacts.aria") %></p>
            <div class="service-contact-grid" aria-label="<%= t("pages.services.contacts.aria") %>">
              <article class="service-contact-card">
                <%= image_tag "russ_live/team/sebastian-kraenzlein.jpg",
                              alt: t("pages.services.contacts.sebastian.name"),
                              loading: "lazy",
                              decoding: "async",
                              width: 1024,
                              height: 1024 %>
                <div class="service-contact-meta">
                  <h3><%= t("pages.services.contacts.sebastian.name") %></h3>
                  <p><%= t("pages.services.contacts.sebastian.role") %></p>
                  <p><%= mail_to t("pages.services.contacts.sebastian.email"), t("pages.services.contacts.sebastian.email") %></p>
                </div>
              </article>
            </div>
          </div>
          <figure class="public-card service-chapter-visual service-chapter-visual-filled">
            <%= image_tag "russ_live/keyvisuals/services-staff.jpg",
                          alt: "",
                          width: 3888,
                          height: 2592,
                          loading: "lazy",
                          decoding: "async" %>
          </figure>
        </article>

<article class="service-chapter" id="ticketing">
          <h2><%= t("services.items.ticketing.title") %></h2>
          <div class="service-chapter-copy">
            <p><%= t("services.items.ticketing.paragraphs.first") %></p>
            <p><%= t("services.items.ticketing.paragraphs.second") %></p>
            <%= link_to "Stuttgart-Live",
                        "https://www.stuttgart-live.de/",
                        class: "public-button public-button-primary section-button",
                        target: "_blank",
                        rel: "noopener noreferrer" %>
          </div>
          <figure class="public-card service-chapter-visual"><span><%= t("pages.services.image_pending") %></span></figure>
        </article>
      </section>

      <% if @service_references.any? %>
        <section class="public-section section services-showcase" aria-labelledby="services-showcase-title">
          <div class="section-head">
            <h2 id="services-showcase-title"><%= t("pages.services.showcase.title") %></h2>
          </div>
          <%= render "pages/reference_slider",
                     references: @service_references,
                     slider_classes: "klassik-slider klassik-slider-page services-reference-slider" %>
        </section>
      <% end %>

      <section class="public-section section service-companies" aria-labelledby="service-companies-title">
        <div class="section-head">
          <h2 id="service-companies-title"><%= t("pages.services.modules.title") %></h2>
        </div>
        <div class="service-company-grid">
<article class="public-card service-company-card">
            <p class="service-company-kicker"><%= t("pages.services.modules.kicker") %></p>
            <h3><%= t("services.items.local.title") %></h3>
            <p><%= t("services.items.local.paragraphs.first") %></p>
            <a href="#local" aria-label="<%= t("pages.services.more_about", title: t("services.items.local.title")) %>"><%= t("pages.services.more") %></a>
          </article>
<article class="public-card service-company-card">
            <p class="service-company-kicker"><%= t("pages.services.modules.kicker") %></p>
            <h3><%= t("services.items.production.title") %></h3>
            <p><%= t("services.items.production.paragraphs.first") %></p>
            <a href="#production" aria-label="<%= t("pages.services.more_about", title: t("services.items.production.title")) %>"><%= t("pages.services.more") %></a>
          </article>
<article class="public-card service-company-card">
            <p class="service-company-kicker"><%= t("pages.services.modules.kicker") %></p>
            <h3><%= t("services.items.marketing.title") %></h3>
            <p><%= t("services.items.marketing.paragraphs.first") %></p>
            <a href="#marketing" aria-label="<%= t("pages.services.more_about", title: t("services.items.marketing.title")) %>"><%= t("pages.services.more") %></a>
          </article>
<article class="public-card service-company-card">
            <p class="service-company-kicker"><%= t("pages.services.modules.kicker") %></p>
            <h3><%= t("services.items.staff.title") %></h3>
            <p><%= t("services.items.staff.paragraphs.first") %></p>
            <a href="#staff" aria-label="<%= t("pages.services.more_about", title: t("services.items.staff.title")) %>"><%= t("pages.services.more") %></a>
          </article>
<article class="public-card service-company-card">
            <p class="service-company-kicker"><%= t("pages.services.modules.kicker") %></p>
            <h3><%= t("services.items.ticketing.title") %></h3>
            <p><%= t("services.items.ticketing.paragraphs.first") %></p>
            <a href="#ticketing" aria-label="<%= t("pages.services.more_about", title: t("services.items.ticketing.title")) %>"><%= t("pages.services.more") %></a>
          </article>
        </div>
      </section>
    </main>
