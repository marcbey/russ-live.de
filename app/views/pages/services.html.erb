<main id="main-content" class="page-main public-page services-page" tabindex="-1">
      <section class="public-hero public-hero-dark services-hero" aria-labelledby="services-title">
        <div class="services-hero-media">
          <%= image_tag "russ_live/keyvisuals/Keyvisual_RussLive.jpg",
                        alt: t("pages.services.hero.image_alt"),
                        width: 9921,
                        height: 6260,
                        decoding: "async",
                        fetchpriority: "high" %>
        </div>
        <div class="services-hero-copy">
          <p class="eyebrow"><%= t("public.header.services") %></p>
          <h1 id="services-title"><span>Live</span><span>Entertainment</span></h1>
          <p><%= t("pages.services.hero.intro") %></p>
        </div>
        <nav class="public-filter-nav services-jump-nav" aria-label="<%= t("pages.services.nav_aria") %>" data-controller="services-jump-nav">
          <a href="#local"><%= t("services.items.local.title") %></a>
          <a href="#production"><%= t("services.items.production.title") %></a>
          <a href="#marketing"><%= t("services.items.marketing.title") %></a>
          <a href="#staff"><%= t("services.items.staff.title") %></a>
          <a href="#ticketing"><%= t("services.items.ticketing.title") %></a>
        </nav>
      </section>

      <section class="public-section section services-intro" aria-labelledby="services-intro-title">
        <p class="eyebrow"><%= t("pages.services.intro.eyebrow") %></p>
        <div>
          <h2 id="services-intro-title"><%= t("pages.services.intro.title") %></h2>
          <p><%= t("pages.services.intro.text") %></p>
        </div>
      </section>

      <section class="service-chapters" aria-label="<%= t("pages.services.details_aria") %>">
<article class="service-chapter" id="local">
          <span class="service-chapter-index">01</span>
          <p class="service-chapter-label"><%= t("pages.services.chapter_label") %></p>
          <h2><%= t("services.items.local.title") %></h2>
          <div class="service-chapter-copy">
            <p><%= t("services.items.local.paragraphs.first") %></p>
            <p><%= t("services.items.local.paragraphs.second") %></p>
          </div>
          <figure class="public-card service-chapter-visual"><span><%= t("pages.services.image_pending") %></span></figure>
        </article>

<article class="service-chapter service-chapter-reverse" id="production">
          <span class="service-chapter-index">02</span>
          <p class="service-chapter-label"><%= t("pages.services.chapter_label") %></p>
          <h2><%= t("services.items.production.title") %></h2>
          <div class="service-chapter-copy">
            <p><%= t("services.items.production.paragraphs.first") %></p>
            <p><%= t("services.items.production.paragraphs.second") %></p>
          </div>
          <figure class="public-card service-chapter-visual"><span><%= t("pages.services.image_pending") %></span></figure>
        </article>

<article class="service-chapter" id="marketing">
          <span class="service-chapter-index">03</span>
          <p class="service-chapter-label"><%= t("pages.services.chapter_label") %></p>
          <h2><%= t("services.items.marketing.title") %></h2>
          <div class="service-chapter-copy">
            <p><%= t("services.items.marketing.paragraphs.first") %></p>
            <p><%= t("pages.home.services.marketing_contact_html") %></p>
          </div>
          <figure class="public-card service-chapter-visual"><span><%= t("pages.services.image_pending") %></span></figure>
        </article>

<article class="service-chapter service-chapter-reverse" id="staff">
          <span class="service-chapter-index">04</span>
          <p class="service-chapter-label"><%= t("pages.services.chapter_label") %></p>
          <h2><%= t("services.items.staff.title") %></h2>
          <div class="service-chapter-copy">
            <p><%= t("services.items.staff.paragraphs.first") %></p>
            <p><%= t("services.items.staff.paragraphs.second") %></p>
          </div>
          <figure class="public-card service-chapter-visual"><span><%= t("pages.services.image_pending") %></span></figure>
        </article>

<article class="service-chapter" id="ticketing">
          <span class="service-chapter-index">05</span>
          <p class="service-chapter-label"><%= t("pages.services.chapter_label") %></p>
          <h2><%= t("services.items.ticketing.title") %></h2>
          <div class="service-chapter-copy">
            <p><%= t("services.items.ticketing.paragraphs.first") %></p>
            <p><%= t("services.items.ticketing.paragraphs.second") %></p>
          </div>
          <figure class="public-card service-chapter-visual"><span><%= t("pages.services.image_pending") %></span></figure>
        </article>
      </section>

      <section class="public-section section services-showcase" aria-labelledby="services-showcase-title">
        <div class="section-head">
          <p class="eyebrow"><%= t("pages.services.showcase.eyebrow") %></p>
          <h2 id="services-showcase-title"><%= t("pages.services.showcase.title") %></h2>
        </div>
        <div class="klassik-slider klassik-slider-page services-reference-slider" data-slider="" data-controller="slider">
          <div class="klassik-slider-viewport">
            <button class="klassik-slider-arrow klassik-slider-arrow-prev" type="button" aria-label="<%= t("references.slider.previous") %>">‹</button>
            <div class="klassik-slider-stage">
              <figure class="klassik-slide is-active" data-index="0" tabindex="0" aria-hidden="false" aria-label="Five Finger Death Punch" data-title="Five Finger Death Punch" data-date-location="Rock / Metal · Porsche-Arena Stuttgart" data-partner="<%= t("references.card.service_reference") %>">
                <%= image_tag "russ_live/references/featured/bild1.jpg", alt: "Five Finger Death Punch", loading: "lazy", decoding: "async", width: 920, height: 400 %>
              </figure>
              <figure class="klassik-slide is-next" data-index="1" tabindex="0" aria-hidden="true" aria-label="AC/DC" data-title="AC/DC" data-date-location="Stadionproduktion · Stuttgart" data-partner="<%= t("references.card.service_reference") %>">
                <%= image_tag "russ_live/references/featured/bild2.jpg", alt: "AC/DC", loading: "lazy", decoding: "async", width: 920, height: 400 %>
              </figure>
              <figure class="klassik-slide is-prev" data-index="2" tabindex="0" aria-hidden="true" aria-label="David Garrett" data-title="David Garrett" data-date-location="Arena-Konzert · Liederhalle Stuttgart" data-partner="<%= t("references.card.service_reference") %>">
                <%= image_tag "russ_live/references/featured/bild3.jpg", alt: "David Garrett", loading: "lazy", decoding: "async", width: 920, height: 400 %>
              </figure>
            </div>
            <button class="klassik-slider-arrow klassik-slider-arrow-next" type="button" aria-label="<%= t("references.slider.next") %>">›</button>
          </div>
          <div class="klassik-slider-meta">
            <span class="klassik-slider-marker" aria-hidden="true"></span>
            <div class="klassik-slider-text">
              <h3>Five Finger Death Punch</h3>
              <p class="klassik-slider-date-location">Rock / Metal · Porsche-Arena Stuttgart</p>
              <p class="klassik-slider-partner"><%= t("references.card.service_reference") %></p>
            </div>
            <a class="public-button public-button-primary section-button klassik-slider-button" href="<%= referenzen_path %>"><%= t("public.header.references") %></a>
          </div>
        </div>
      </section>

      <section class="public-section section service-companies" aria-labelledby="service-companies-title">
        <div class="section-head">
          <p class="eyebrow"><%= t("pages.services.modules.eyebrow") %></p>
          <h2 id="service-companies-title"><%= t("pages.services.modules.title") %></h2>
        </div>
        <div class="service-company-grid">
<article class="public-card service-company-card">
            <p class="service-company-kicker"><%= t("pages.services.modules.kicker") %></p>
            <h3><%= t("services.items.local.title") %></h3>
            <p><%= t("services.items.local.paragraphs.first") %></p>
            <a href="#local" aria-label="<%= t("pages.services.more_about", title: t("services.items.local.title")) %>"><%= t("pages.services.more") %></a>
          </article>
<article class="public-card service-company-card">
            <p class="service-company-kicker"><%= t("pages.services.modules.kicker") %></p>
            <h3><%= t("services.items.production.title") %></h3>
            <p><%= t("services.items.production.paragraphs.first") %></p>
            <a href="#production" aria-label="<%= t("pages.services.more_about", title: t("services.items.production.title")) %>"><%= t("pages.services.more") %></a>
          </article>
<article class="public-card service-company-card">
            <p class="service-company-kicker"><%= t("pages.services.modules.kicker") %></p>
            <h3><%= t("services.items.marketing.title") %></h3>
            <p><%= t("services.items.marketing.paragraphs.first") %></p>
            <a href="#marketing" aria-label="<%= t("pages.services.more_about", title: t("services.items.marketing.title")) %>"><%= t("pages.services.more") %></a>
          </article>
<article class="public-card service-company-card">
            <p class="service-company-kicker"><%= t("pages.services.modules.kicker") %></p>
            <h3><%= t("services.items.staff.title") %></h3>
            <p><%= t("services.items.staff.paragraphs.first") %></p>
            <a href="#staff" aria-label="<%= t("pages.services.more_about", title: t("services.items.staff.title")) %>"><%= t("pages.services.more") %></a>
          </article>
<article class="public-card service-company-card">
            <p class="service-company-kicker"><%= t("pages.services.modules.kicker") %></p>
            <h3><%= t("services.items.ticketing.title") %></h3>
            <p><%= t("services.items.ticketing.paragraphs.first") %></p>
            <a href="#ticketing" aria-label="<%= t("pages.services.more_about", title: t("services.items.ticketing.title")) %>"><%= t("pages.services.more") %></a>
          </article>
        </div>
      </section>
    </main>
