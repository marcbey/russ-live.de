output/

# Ignore key files for decrypting credentials and more.
/config/*.key

# Ignore application logs and temporary files.
/log/*
!/log/.keep
/tmp/*
!/tmp/.keep
!/tmp/pids
/tmp/pids/*
!/tmp/pids/.keep
!/tmp/storage
/tmp/storage/*
!/tmp/storage/.keep

# Ignore uploaded files in development.
/storage/*
!/storage/.keep

/app/assets/builds/*
!/app/assets/builds/.keep

/node_modules
